    {"from": "settlement_agent", "to": "custodian", "artifact": "settlement_instruction", "protocol": "SWIFT MT540"},
    {"from": "custodian", "to": "investment_manager", "artifact": "settlement_confirmation", "protocol": "SWIFT MT542"}
  ],
  "description": "Post-trade processing workflow from trade confirmation through clearing and settlement to custody. Uses FIX 5.0 for pre-settlement and SWIFT for settlement instructions."
}
