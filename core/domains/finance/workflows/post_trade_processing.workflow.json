{
  "workflow": "post_trade_processing",
  "domain": "finance",
  "protocol": "FIX 5.0",
  "handoffs": [
    {"from": "execution_venue", "to": "clearing_house", "artifact": "trade_confirmation", "protocol": "FIX 5.0"},
