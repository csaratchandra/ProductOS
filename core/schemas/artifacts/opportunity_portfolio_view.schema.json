{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/opportunity_portfolio_view.schema.json",
  "title": "ProductOS Opportunity Portfolio View",
  "description": "Opportunity-level portfolio used to allocate discovery attention and learning effort.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "opportunity_portfolio_view_id",
    "workspace_id",
    "title",
    "summary",
    "framework_registry_ref",
    "selected_framework_ids",
    "ranking_method_summary",
    "recommended_now_ids",
    "opportunities",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1.0" },
    "opportunity_portfolio_view_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "summary": { "type": "string", "minLength": 10 },
    "framework_registry_ref": { "type": "string", "minLength": 1 },
    "selected_framework_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "ranking_method_summary": { "type": "string", "minLength": 10 },
    "recommended_now_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "opportunities": {
      "type": "array",
      "items": { "$ref": "#/$defs/opportunity" },
      "minItems": 1
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "opportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opportunity_id",
        "title",
        "value_at_stake",
        "strategic_fit",
        "confidence",
        "time_sensitivity",
        "reversibility",
        "learning_potential",
        "evidence_freshness",
        "priority_score",
        "priority_lane",
        "agentic_delivery_leverage",
        "delivery_burden",
        "rationale",
        "source_artifact_ids"
      ],
      "properties": {
        "opportunity_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 3 },
        "value_at_stake": {
          "type": "string",
          "enum": ["low", "moderate", "high", "transformational"]
        },
        "strategic_fit": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "time_sensitivity": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "reversibility": {
          "type": "string",
          "enum": ["easy", "moderate", "hard"]
        },
        "learning_potential": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "evidence_freshness": {
          "type": "string",
          "enum": ["stale", "current", "fresh"]
        },
        "priority_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "priority_lane": {
          "type": "string",
          "enum": ["must_now", "next", "later", "park"]
        },
        "agentic_delivery_leverage": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "delivery_burden": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "rationale": {
          "type": "string",
          "minLength": 10
        },
        "source_artifact_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
}
