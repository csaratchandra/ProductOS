{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/persona_narrative_card.schema.json",
  "title": "ProductOS Persona Narrative Card",
  "description": "Rich narrative persona profile with AI-generated day-in-the-life story, voice samples, behavioral profile, decision journey, relationship map, use case inventory, satisfaction drivers, and one-page visual card rendering spec.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "persona_narrative_card_id",
    "workspace_id",
    "persona_archetype_pack_ref",
    "persona_ref",
    "name",
    "identity",
    "day_in_the_life",
    "voice_samples",
    "behavioral_profile",
    "decision_journey",
    "use_cases",
    "satisfaction_drivers",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "persona_narrative_card_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "persona_archetype_pack_ref": { "type": "string", "minLength": 1 },
    "persona_ref": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 3 },
    "identity": { "$ref": "#/$defs/identity" },
    "day_in_the_life": { "$ref": "#/$defs/dayInTheLife" },
    "voice_samples": {
      "type": "array",
      "items": { "$ref": "#/$defs/voiceSample" },
      "minItems": 3
    },
    "behavioral_profile": { "$ref": "#/$defs/behavioralProfile" },
    "decision_journey": { "$ref": "#/$defs/decisionJourney" },
    "relationship_map": { "$ref": "#/$defs/relationshipMap" },
    "use_cases": { "$ref": "#/$defs/useCases" },
    "satisfaction_drivers": { "$ref": "#/$defs/satisfactionDrivers" },
    "maturity_band_variation": { "$ref": "#/$defs/maturityBandVariation" },
    "visual_card_spec": { "$ref": "#/$defs/visualCardSpec" },
    "source_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["age_range", "location", "education", "role_title", "years_in_role", "reports_to", "team_size", "career_stage", "photo_description"],
      "properties": {
        "age_range": { "type": "string", "minLength": 3 },
        "location": { "type": "string", "minLength": 3 },
        "education": { "type": "string", "minLength": 5 },
        "role_title": { "type": "string", "minLength": 5 },
        "years_in_role": { "type": "string", "minLength": 3 },
        "reports_to": { "type": "string", "minLength": 5 },
        "team_size": { "type": "string", "minLength": 3 },
        "career_stage": { "type": "string", "enum": ["early_career", "mid_career", "senior", "executive"] },
        "photo_description": { "type": "string", "minLength": 20 }
      }
    },
    "dayInTheLife": {
      "type": "object",
      "additionalProperties": false,
      "required": ["morning_routine", "core_workday", "afternoon_challenges", "evening_reflection", "weekly_rhythm"],
      "properties": {
        "morning_routine": { "type": "string", "minLength": 30 },
        "core_workday": { "type": "string", "minLength": 30 },
        "afternoon_challenges": { "type": "string", "minLength": 30 },
        "evening_reflection": { "type": "string", "minLength": 30 },
        "weekly_rhythm": { "type": "string", "minLength": 30 }
      }
    },
    "voiceSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context", "quote", "tone"],
      "properties": {
        "context": { "type": "string", "minLength": 10 },
        "quote": { "type": "string", "minLength": 20 },
        "tone": { "type": "string", "minLength": 3 }
      }
    },
    "behavioralProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["technology_comfort", "learning_style", "communication_preference", "daily_tools", "switch_cost"],
      "properties": {
        "technology_comfort": { "type": "string", "enum": ["novice", "intermediate", "expert", "early_adopter"] },
        "learning_style": { "type": "string", "enum": ["self_serve", "guided", "peer_learn", "structured_training"] },
        "communication_preference": { "type": "string", "enum": ["async", "sync", "mixed"] },
        "daily_tools": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 3 },
        "switch_cost": { "type": "string", "enum": ["low", "medium", "high"] },
        "switch_cost_rationale": { "type": "string", "minLength": 10 }
      }
    },
    "decisionJourney": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discovery_channel", "evaluation_criteria", "decision_authority", "budget_signoff_needed", "evaluation_timeline", "influencers", "deal_killers"],
      "properties": {
        "discovery_channel": { "type": "string", "minLength": 10 },
        "evaluation_criteria": { "type": "array", "items": { "$ref": "#/$defs/rankedCriterion" }, "minItems": 3 },
        "decision_authority": { "type": "string", "enum": ["sole_decider", "primary_recommender", "committee_member", "informed_only"] },
        "budget_signoff_needed": { "type": "boolean" },
        "evaluation_timeline": { "type": "string", "minLength": 5 },
        "influencers": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
        "deal_killers": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 1 }
      }
    },
    "rankedCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "criterion", "weight"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "criterion": { "type": "string", "minLength": 3 },
        "weight": { "type": "string", "enum": ["must_have", "high", "medium", "nice_to_have"] }
      }
    },
    "relationshipMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["influences", "influenced_by", "reports_to_chain", "primary_collaborators", "conflicts_with"],
      "properties": {
        "influences": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
        "influenced_by": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
        "reports_to_chain": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
        "primary_collaborators": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
        "conflicts_with": { "type": "array", "items": { "type": "string", "minLength": 3 }, "default": [] }
      }
    },
    "useCases": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary", "edge", "anti_use"],
      "properties": {
        "primary": { "$ref": "#/$defs/useCaseDetail" },
        "secondary": { "$ref": "#/$defs/useCaseDetail" },
        "edge": { "$ref": "#/$defs/useCaseDetail" },
        "anti_use": { "$ref": "#/$defs/useCaseDetail" }
      }
    },
    "useCaseDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario", "frequency", "criticality", "outcome_if_solved"],
      "properties": {
        "scenario": { "type": "string", "minLength": 20 },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly", "rarely"] },
        "criticality": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "outcome_if_solved": { "type": "string", "minLength": 10 }
      }
    },
    "satisfactionDrivers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_haves", "delighters", "detractors", "indifference_zone"],
      "properties": {
        "must_haves": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 3 },
        "delighters": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 2 },
        "detractors": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 2 },
        "indifference_zone": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "default": []
        }
      }
    },
    "maturityBandVariation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zero_to_one_behavior", "one_to_ten_behavior", "ten_to_hundred_behavior"],
      "properties": {
        "zero_to_one_behavior": { "type": "string", "minLength": 10 },
        "one_to_ten_behavior": { "type": "string", "minLength": 10 },
        "ten_to_hundred_behavior": { "type": "string", "minLength": 10 },
        "hundred_plus_behavior": { "type": "string", "minLength": 10 }
      }
    },
    "visualCardSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "sections", "layout", "color_palette"],
      "properties": {
        "title": { "type": "string", "minLength": 5 },
        "sections": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 3 },
        "layout": { "type": "string", "enum": ["one_page_profile", "two_page_detailed", "workshop_poster"] },
        "color_palette": { "type": "string", "minLength": 3 },
        "quote_pullout": { "type": "string", "minLength": 20 }
      }
    }
  }
}