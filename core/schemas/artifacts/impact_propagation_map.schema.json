{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/impact_propagation_map.schema.json",
  "title": "ProductOS Impact Propagation Map",
  "description": "Artifact dependency impact propagation map — traces how changes cascade through downstream artifacts with regeneration recommendations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "impact_propagation_map_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "impact_propagation_map_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}