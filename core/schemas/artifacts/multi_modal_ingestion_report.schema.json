{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/multi_modal_ingestion_report.schema.json",
  "title": "ProductOS Multi-Modal Ingestion Report",
  "description": "Tracks every ingested source during takeover: type, path, extraction confidence, extracted entities, cross-source contradictions, and ingestion coverage gaps.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ingestion_report_id",
    "workspace_id",
    "ingested_sources",
    "contradictions_found",
    "ingestion_coverage",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "ingestion_report_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "ingested_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/ingestedSource" },
      "minItems": 1
    },
    "contradictions_found": {
      "type": "array",
      "items": { "$ref": "#/$defs/contradiction" }
    },
    "ingestion_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain_areas", "overall_coverage_pct"],
      "properties": {
        "domain_areas": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainCoverage" }
        },
        "overall_coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "gap_areas": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "ingestedSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "source_path", "extraction_confidence", "extracted_entities"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_path": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": ["code_repo", "prd_document", "strategy_doc", "screenshot", "transcript", "meeting_notes", "competitor_analysis", "research_report", "email", "other"]
        },
        "extraction_confidence": {
          "type": "string",
          "enum": ["observed", "inferred", "uncertain"]
        },
        "extracted_entities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "problems": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "personas": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "features": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "decisions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "competitors": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "metrics": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "ingested_at": { "type": "string", "format": "date-time" },
        "error": { "type": "string" }
      }
    },
    "contradiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contradiction_id", "description", "sources_involved", "severity"],
      "properties": {
        "contradiction_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 10 },
        "sources_involved": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 2
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "resolution_recommendation": { "type": "string" }
      }
    },
    "domainCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "coverage_pct", "status"],
      "properties": {
        "domain": { "type": "string", "minLength": 1 },
        "coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "type": "string",
          "enum": ["well_covered", "partial", "gap_heavy", "not_covered"]
        },
        "missing_sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
