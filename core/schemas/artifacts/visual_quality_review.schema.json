{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/visual_quality_review.schema.json",
  "title": "ProductOS Visual Quality Review",
  "description": "Shared review artifact that records quality, blockers, and next action for a generated visual surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "visual_quality_review_id",
    "workspace_id",
    "visual_surface",
    "source_artifact_id",
    "visual_direction_plan_ref",
    "output_ref",
    "review_status",
    "publish_ready",
    "narrative_clarity_score",
    "visual_hierarchy_score",
    "evidence_visibility_score",
    "audience_fit_score",
    "fidelity_score",
    "strengths",
    "warnings",
    "blockers",
    "recommended_next_action",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "visual_quality_review_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "visual_surface": {
      "type": "string",
      "enum": ["deck", "corridor", "map"]
    },
    "source_artifact_id": { "type": "string", "minLength": 1 },
    "visual_direction_plan_ref": { "type": "string", "minLength": 1 },
    "output_ref": { "type": "string", "minLength": 1 },
    "review_status": {
      "type": "string",
      "enum": ["pass", "revise", "block"]
    },
    "publish_ready": { "type": "boolean" },
    "narrative_clarity_score": { "type": "number", "minimum": 0, "maximum": 5 },
    "visual_hierarchy_score": { "type": "number", "minimum": 0, "maximum": 5 },
    "evidence_visibility_score": { "type": "number", "minimum": 0, "maximum": 5 },
    "audience_fit_score": { "type": "number", "minimum": 0, "maximum": 5 },
    "fidelity_score": { "type": "number", "minimum": 0, "maximum": 5 },
    "strengths": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "minItems": 1
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "default": []
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "default": []
    },
    "recommended_next_action": {
      "type": "string",
      "enum": ["proceed", "revise", "defer", "block"]
    },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
