{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/workspace_registration.schema.json",
  "title": "ProductOS Workspace Registration",
  "description": "Registry record describing a workspace and its adopted ProductOS Core version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registration_id",
    "workspace_id",
    "workspace_name",
    "current_core_version",
    "upgrade_history",
    "registered_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "registration_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_name": {
      "type": "string",
      "minLength": 3
    },
    "current_core_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "upgrade_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/upgradeRecord"
      },
      "minItems": 1
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "upgradeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_version",
        "adopted_at",
        "approved_by",
        "change_note"
      ],
      "properties": {
        "core_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "adopted_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "change_note": {
          "type": "string",
          "minLength": 5
        }
      }
    }
  }
}
