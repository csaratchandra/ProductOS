{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/outcome_cascade.schema.json",
  "title": "ProductOS Outcome Cascade",
  "description": "Outcome cascade mapping business outcomes to product outcomes, feature metrics, user actions, and data sources with confidence scoring and measurement gap detection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "outcome_cascade_id", "architecture_ref", "cascade", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "outcome_cascade_id": { "type": "string", "minLength": 1 },
    "architecture_ref": { "type": "string", "minLength": 1 },
    "cascade": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "entries"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["Business Outcome", "Product Outcome", "Feature Metric", "User Action", "Data Source"]
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "confidence": { "type": "string", "enum": ["observed", "inferred", "assumed"] },
                "measurement": { "type": "string" },
                "data_source": { "type": "string" },
                "linked_business_outcome": { "type": "string" },
                "linked_feature_metric": { "type": "string" },
                "measurement_gap": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "measurement_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["outcome_ref", "gap"],
        "properties": {
          "outcome_ref": { "type": "string", "minLength": 1 },
          "gap": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
