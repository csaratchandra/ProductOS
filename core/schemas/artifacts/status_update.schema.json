{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/status_update.schema.json",
  "title": "ProductOS Status Update",
  "description": "A concise structured status update that can be adapted into status mail, leadership summaries, or other renderings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status_update_id",
    "workspace_id",
    "audience",
    "headline",
    "status",
    "highlights",
    "risks",
    "next_steps",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "status_update_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "headline": {
      "type": "string",
      "minLength": 5
    },
    "status": {
      "type": "string",
      "enum": [
        "on_track",
        "watch",
        "at_risk",
        "blocked"
      ]
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "default": []
    },
    "next_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionItem"
      },
      "minItems": 1
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "actionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "owner",
        "target_date"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 5
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "target_date": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
