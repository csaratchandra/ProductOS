{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/roadmap_scenario.schema.json",
  "title": "ProductOS Roadmap Scenario",
  "description": "Multi-scenario roadmap with optimistic, expected, and pessimistic timelines incorporating dependency sequencing, capacity constraints, risk-adjusted milestone confidence, and stakeholder-specific views derived from a single source of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "roadmap_scenario_id", "workspace_id", "title", "time_horizon_months", "scenarios", "shared_dependencies", "okr_alignment", "generated_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "roadmap_scenario_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 5},
    "time_horizon_months": {"type": "integer", "minimum": 3, "maximum": 24},
    "scenarios": {"type": "array", "items": {"$ref": "#/$defs/scenario"}, "minItems": 2, "maxItems": 3},
    "shared_dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}, "minItems": 1},
    "critical_path": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "okr_alignment": {"$ref": "#/$defs/okrAlignment"},
    "stakeholder_views": {"type": "array", "items": {"$ref": "#/$defs/stakeholderView"}, "default": []},
    "source_evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "default": []},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "scenario": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "type", "milestones", "risk_level", "probability_of_on_time_delivery"],
      "properties": {
        "name": {"type": "string", "minLength": 3},
        "type": {"type": "string", "enum": ["optimistic", "expected", "pessimistic"]},
        "description": {"type": "string", "minLength": 10},
        "milestones": {"type": "array", "items": {"$ref": "#/$defs/milestone"}, "minItems": 2},
        "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
        "probability_of_on_time_delivery": {"type": "integer", "minimum": 0, "maximum": 100}
      }
    },
    "milestone": {
      "type": "object", "additionalProperties": false,
      "required": ["milestone_id", "title", "sprint_number", "features", "confidence"],
      "properties": {
        "milestone_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 3},
        "sprint_number": {"type": "integer", "minimum": 1},
        "features": {"type": "array", "items": {"$ref": "#/$defs/roadmapFeature"}, "minItems": 1},
        "confidence": {"type": "string", "enum": ["high", "moderate", "low"]},
        "depends_on_milestones": {"type": "array", "items": {"type": "string", "minLength": 1}, "default": []}
      }
    },
    "roadmapFeature": {
      "type": "object", "additionalProperties": false,
      "required": ["feature_id", "name", "story_points", "owner_team"],
      "properties": {
        "feature_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 3},
        "story_points": {"type": "integer", "minimum": 1},
        "owner_team": {"type": "string", "minLength": 3},
        "status": {"type": "string", "enum": ["planned", "in_progress", "at_risk", "done"]},
        "linked_outcome_id": {"type": "string", "minLength": 1}
      }
    },
    "dependency": {
      "type": "object", "additionalProperties": false,
      "required": ["from_feature_id", "to_feature_id", "type"],
      "properties": {
        "from_feature_id": {"type": "string", "minLength": 1},
        "to_feature_id": {"type": "string", "minLength": 1},
        "type": {"type": "string", "enum": ["blocks", "enables", "integrates_with"]},
        "description": {"type": "string", "minLength": 10}
      }
    },
    "okrAlignment": {
      "type": "object", "additionalProperties": false,
      "required": ["company_objective", "product_key_results", "feature_metric_map"],
      "properties": {
        "company_objective": {"type": "string", "minLength": 10},
        "product_key_results": {"type": "array", "items": {"type": "string", "minLength": 10}, "minItems": 1},
        "feature_metric_map": {"type": "array", "items": {"$ref": "#/$defs/featureMetricLink"}, "minItems": 1}
      }
    },
    "featureMetricLink": {
      "type": "object", "additionalProperties": false,
      "required": ["feature_id", "metric", "target", "measurement_method"],
      "properties": {
        "feature_id": {"type": "string", "minLength": 1},
        "metric": {"type": "string", "minLength": 3},
        "target": {"type": "string", "minLength": 3},
        "measurement_method": {"type": "string", "minLength": 5}
      }
    },
    "stakeholderView": {
      "type": "object", "additionalProperties": false,
      "required": ["audience", "visible_elements", "generated_from"],
      "properties": {
        "audience": {"type": "string", "enum": ["executive", "engineering", "customer", "internal_team"]},
        "visible_elements": {"type": "array", "items": {"type": "string", "minLength": 3}, "minItems": 1},
        "generated_from": {"type": "string", "minLength": 3}
      }
    }
  }
}