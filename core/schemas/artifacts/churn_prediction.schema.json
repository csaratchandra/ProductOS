{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/churn_prediction.schema.json",
  "title": "ProductOS Churn Prediction",
  "description": "Customer churn prediction model — risk scoring, early warning signals, intervention recommendations per account.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "churn_prediction_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "churn_prediction_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}