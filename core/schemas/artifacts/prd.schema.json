{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prd.schema.json",
  "title": "ProductOS PRD",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prd_id",
    "workspace_id",
    "title",
    "problem_summary",
    "outcome_summary",
    "scope_summary",
    "strategic_context_summary",
    "value_hypothesis",
    "target_outcomes",
    "target_segment_refs",
    "target_persona_refs",
    "linked_entity_refs",
    "upstream_artifact_ids",
    "canonical_persona_archetype_pack_id",
    "artifact_trace_map_id",
    "ralph_status",
    "prioritization",
    "scope_boundaries",
    "out_of_scope",
    "open_questions",
    "handoff_risks",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1.0" },
    "prd_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "problem_summary": { "type": "string", "minLength": 10 },
    "outcome_summary": { "type": "string", "minLength": 10 },
    "scope_summary": { "type": "string", "minLength": 10 },
    "strategic_context_summary": { "type": "string", "minLength": 10 },
    "value_hypothesis": { "type": "string", "minLength": 10 },
    "target_outcomes": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "target_segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "target_persona_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "linked_entity_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "upstream_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "canonical_persona_archetype_pack_id": { "type": "string", "minLength": 1 },
    "artifact_trace_map_id": { "type": "string", "minLength": 1 },
    "ralph_status": {
      "type": "string",
      "enum": ["blocked", "review_needed", "decision_ready"]
    },
    "prioritization": { "$ref": "#/$defs/prioritization" },
    "scope_boundaries": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "handoff_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "prioritization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "priority_score", "confidence", "agentic_delivery_burden", "priority_rationale", "reviewer_handoff"],
      "properties": {
        "lane": {
          "type": "string",
          "enum": ["must_now", "next", "later", "park"]
        },
        "priority_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "agentic_delivery_burden": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "priority_rationale": { "type": "string", "minLength": 10 },
        "reviewer_handoff": { "type": "string", "minLength": 10 }
      }
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
