{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/compliance_review_state.schema.json",
  "title": "ProductOS Compliance Review State",
  "description": "Tracks privacy, policy, and compliance review outcomes for an artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_state_id",
    "workspace_id",
    "artifact_id",
    "privacy_review_status",
    "policy_review_status",
    "compliance_review_status",
    "publish_blocked",
    "reviewed_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "review_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "privacy_review_status": {
      "$ref": "#/$defs/reviewStatus"
    },
    "policy_review_status": {
      "$ref": "#/$defs/reviewStatus"
    },
    "compliance_review_status": {
      "$ref": "#/$defs/reviewStatus"
    },
    "publish_blocked": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "reviewStatus": {
      "type": "string",
      "enum": [
        "not_required",
        "pending",
        "approved",
        "rejected"
      ]
    }
  }
}
