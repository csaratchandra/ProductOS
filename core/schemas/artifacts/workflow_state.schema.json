{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/workflow_state.schema.json",
  "title": "ProductOS Workflow State",
  "description": "Reusable runtime state for any ProductOS workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_state_id",
    "workspace_id",
    "workflow_id",
    "workflow_name",
    "workflow_type",
    "status",
    "current_step",
    "steps",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_name": {
      "type": "string",
      "minLength": 3
    },
    "workflow_type": {
      "type": "string",
      "enum": [
        "communication",
        "support",
        "decision_intelligence",
        "delivery",
        "research",
        "leadership",
        "custom"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "collecting_inputs",
        "in_progress",
        "review_needed",
        "blocked",
        "completed",
        "cancelled"
      ]
    },
    "current_step": {
      "type": "string",
      "minLength": 1
    },
    "assigned_agents": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "input_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "output_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "pending_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      },
      "minItems": 1
    },
    "audit_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditEvent"
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "name",
        "status"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 3
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "active",
            "completed",
            "blocked",
            "skipped"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "auditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "event_type",
        "message"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "created",
            "step_transition",
            "artifact_attached",
            "question_raised",
            "blocked",
            "completed"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 3
        }
      }
    }
  }
}
