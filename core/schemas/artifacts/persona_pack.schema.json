{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/persona_pack.schema.json",
  "title": "ProductOS Persona Pack",
  "description": "Structured persona summary pack for discovery and problem framing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "persona_pack_id",
    "workspace_id",
    "title",
    "segment_refs",
    "personas",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "persona_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "segment_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityRef"
      },
      "minItems": 1
    },
    "personas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/personaSummary"
      },
      "minItems": 1
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona"]
        },
        "entity_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "personaSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona_ref",
        "role",
        "goals",
        "pains"
      ],
      "properties": {
        "persona_ref": {
          "$ref": "#/$defs/entityRef"
        },
        "role": {
          "type": "string",
          "minLength": 3
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "minItems": 1
        },
        "pains": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "minItems": 1
        },
        "behavior_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "default": []
        }
      }
    }
  }
}
