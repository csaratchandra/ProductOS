{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/funnel_analysis.schema.json",
  "title": "ProductOS Funnel Analysis",
  "description": "Product funnel analytics — stage-by-stage conversion, drop-off identification, funnel optimization recommendations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "funnel_analysis_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "funnel_analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}