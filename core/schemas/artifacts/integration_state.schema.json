{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/integration_state.schema.json",
  "title": "ProductOS Integration State",
  "description": "Runtime integration health and source-of-truth evaluation state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "integration_state_id",
    "workspace_id",
    "status",
    "stale_connectors",
    "failed_connectors",
    "source_of_truth_conflicts",
    "evaluated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "integration_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "watch",
        "blocked"
      ]
    },
    "stale_connectors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "failed_connectors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "source_of_truth_conflicts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "publish_blocked": {
      "type": "boolean",
      "default": false
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
