{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/consultant_report_digest.schema.json",
  "title": "ProductOS Consultant Report Digest",
  "description": "Decision-oriented digest of a consultant or market report with reusable claims and caveats.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consultant_report_digest_id",
    "workspace_id",
    "title",
    "source_artifact_id",
    "thesis",
    "relevant_claims",
    "strategic_implications",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "consultant_report_digest_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "source_artifact_id": { "type": "string", "minLength": 1 },
    "thesis": { "type": "string", "minLength": 10 },
    "relevant_claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" },
      "minItems": 1
    },
    "reusable_assets": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "strategic_implications": {
      "type": "array",
      "items": { "type": "string", "minLength": 10 },
      "minItems": 1
    },
    "contradictions": {
      "type": "array",
      "items": { "type": "string", "minLength": 10 },
      "default": []
    },
    "caveats": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "relevance"],
      "properties": {
        "statement": { "type": "string", "minLength": 10 },
        "relevance": { "type": "string", "minLength": 5 }
      }
    }
  }
}
