{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/analytics_plan.schema.json",
  "title": "ProductOS Analytics Plan",
  "description": "Auto-generated analytics instrumentation plan with event taxonomy, metrics, funnel predictions, A/B test candidates, privacy risk assessment, and dashboard specs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "analytics_plan_id", "architecture_ref", "event_taxonomy", "metric_definitions", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "analytics_plan_id": { "type": "string", "minLength": 1 },
    "architecture_ref": { "type": "string", "minLength": 1 },
    "event_taxonomy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_name", "trigger", "persona_ref", "properties"],
        "properties": {
          "event_name": { "type": "string" },
          "trigger": { "type": "string" },
          "persona_ref": { "type": "string" },
          "properties": { "type": "array", "items": { "type": "string" } },
          "privacy_classification": { "type": "string", "enum": ["pii", "phi", "financial", "behavioral", "technical", "none"] }
        }
      }
    },
    "metric_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric_name", "formula", "data_sources"],
        "properties": {
          "metric_name": { "type": "string" },
          "formula": { "type": "string" },
          "data_sources": { "type": "array", "items": { "type": "string" } },
          "aggregation": { "type": "string" },
          "alert_threshold": { "type": "string" }
        }
      }
    },
    "predicted_funnel_dropoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "predicted_dropoff_rate", "suggested_improvement"],
        "properties": {
          "stage": { "type": "string" },
          "predicted_dropoff_rate": { "type": "number" },
          "suggested_improvement": { "type": "string" }
        }
      }
    },
    "ab_test_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "hypothesis": { "type": "string" },
          "target_metric": { "type": "string" },
          "expected_lift": { "type": "string" },
          "required_sample_size": { "type": "integer" }
        }
      }
    },
    "privacy_risk_assessment": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event": { "type": "string" },
          "regulation": { "type": "string" },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "dashboard_specs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "audience": { "type": "string" },
          "widgets": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
