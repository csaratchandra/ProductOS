{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/help_manual_pack.schema.json",
  "title": "ProductOS Help Manual Pack",
  "description": "Complete help manual structure — Getting Started, Core Features, Advanced Usage, Troubleshooting, FAQ, Security, Glossary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "help_manual_pack_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "help_manual_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}