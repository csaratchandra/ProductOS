{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/gap_analysis.schema.json",
  "title": "ProductOS Gap Analysis",
  "description": "Cross-layer gap detection with narrative explanations, impact statements, fix suggestions, and auto-fix support.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gap_analysis_id",
    "architecture_ref",
    "gaps",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "gap_analysis_id": { "type": "string", "minLength": 1 },
    "architecture_ref": { "type": "string", "minLength": 1 },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" },
      "default": []
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_gaps": { "type": "integer", "minimum": 0 },
        "critical_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "info_count": { "type": "integer", "minimum": 0 },
        "auto_fixable_count": { "type": "integer", "minimum": 0 }
      },
      "required": ["total_gaps", "critical_count", "warning_count", "info_count"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "gap_type",
        "severity",
        "description",
        "impact",
        "suggestion",
        "confidence"
      ],
      "properties": {
        "gap_id": { "type": "string", "minLength": 1 },
        "gap_type": {
          "type": "string",
          "enum": [
            "missing_handoff",
            "orphan_persona",
            "sla_inconsistency",
            "compliance_gap",
            "persona_coverage_gap",
            "api_contract_gap",
            "outcome_measurement_gap",
            "broken_cross_layer_link",
            "circular_dependency"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "warning", "info"]
        },
        "description": { "type": "string", "minLength": 10 },
        "impact": { "type": "string", "minLength": 10 },
        "suggestion": { "type": "string", "minLength": 10 },
        "auto_fix_available": { "type": "boolean", "default": false },
        "auto_fix_payload": { "type": "object", "default": {} },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "affected_artifact_uuids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  }
}
