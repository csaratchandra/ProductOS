{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/hypothesis_portfolio.schema.json",
  "title": "ProductOS Hypothesis Portfolio",
  "description": "Structured portfolio of linked hypotheses with tree decomposition (strategic → tactical → testable), interdependency mapping, kill criteria per hypothesis, risk prioritization (impact × uncertainty), validation status tracking, and auto-routing into prototype generation for highest-risk hypotheses.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "hypothesis_portfolio_id", "workspace_id", "title",
    "hypotheses", "interdependencies", "risk_prioritization", "portfolio_summary", "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "hypothesis_portfolio_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "hypotheses": { "type": "array", "items": { "$ref": "#/$defs/hypothesis" }, "minItems": 3 },
    "interdependencies": { "type": "array", "items": { "$ref": "#/$defs/interdependency" }, "minItems": 1 },
    "risk_prioritization": { "$ref": "#/$defs/riskPrioritization" },
    "portfolio_summary": { "$ref": "#/$defs/portfolioSummary" },
    "prototype_routing": { "type": "array", "items": { "$ref": "#/$defs/prototypeRoute" }, "default": [] },
    "source_evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "hypothesis": {
      "type": "object", "additionalProperties": false,
      "required": ["hypothesis_id", "statement", "type", "level", "status", "validation_method", "kill_criteria"],
      "properties": {
        "hypothesis_id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 10 },
        "type": { "type": "string", "enum": ["value", "usability", "feasibility", "go_to_market", "retention", "pricing", "competitive", "ecosystem"] },
        "level": { "type": "string", "enum": ["strategic", "tactical", "testable"] },
        "parent_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["draft", "planned", "in_test", "validated", "invalidated", "inconclusive"] },
        "validation_method": { "type": "string", "minLength": 10 },
        "kill_criteria": { "type": "string", "minLength": 10 },
        "impact_if_true": { "type": "string", "enum": ["transformative", "significant", "incremental", "negligible"] },
        "uncertainty": { "type": "string", "enum": ["high", "medium", "low"] },
        "risk_priority_score": { "type": "integer", "minimum": 1, "maximum": 100 },
        "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "last_evaluated_at": { "type": "string", "format": "date-time" }
      }
    },
    "interdependency": {
      "type": "object", "additionalProperties": false,
      "required": ["from_id", "to_id", "relationship"],
      "properties": {
        "from_id": { "type": "string", "minLength": 1 },
        "to_id": { "type": "string", "minLength": 1 },
        "relationship": { "type": "string", "enum": ["depends_on", "mutually_reinforcing", "mutually_exclusive", "supersedes"] },
        "description": { "type": "string", "minLength": 10 }
      }
    },
    "riskPrioritization": {
      "type": "object", "additionalProperties": false,
      "required": ["top_risk_hypotheses", "risk_heat_assessment"],
      "properties": {
        "top_risk_hypotheses": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "risk_heat_assessment": { "type": "string", "minLength": 10 }
      }
    },
    "portfolioSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["total", "by_status", "by_level", "risk_distribution"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "by_status": { "$ref": "#/$defs/distribution" },
        "by_level": { "$ref": "#/$defs/distribution" },
        "risk_distribution": { "type": "string", "minLength": 10 }
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "prototypeRoute": {
      "type": "object", "additionalProperties": false,
      "required": ["hypothesis_id", "priority", "rationale", "suggested_prototype_type"],
      "properties": {
        "hypothesis_id": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["must_now", "next", "later"] },
        "rationale": { "type": "string", "minLength": 10 },
        "suggested_prototype_type": { "type": "string", "enum": ["interactive_html", "visual_mockup", "service_blueprint", "pitch"] }
      }
    }
  }
}