{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/external_research_review.schema.json",
  "title": "ProductOS External Research Review",
  "description": "Quality and contradiction review for accepted external research sources.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "external_research_review_id",
    "workspace_id",
    "review_status",
    "accepted_source_ids",
    "contradiction_items",
    "review_items",
    "recommendation",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "external_research_review_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "review_status": {
      "type": "string",
      "enum": ["clear", "review_required"]
    },
    "accepted_source_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "contradiction_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/contradictionItem" },
      "default": []
    },
    "review_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 10 },
      "default": []
    },
    "recommendation": {
      "type": "string",
      "enum": ["continue_with_refresh", "pm_review_required"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "contradictionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contradiction_id",
        "topic",
        "severity",
        "statement",
        "source_ids"
      ],
      "properties": {
        "contradiction_id": { "type": "string", "minLength": 1 },
        "topic": {
          "type": "string",
          "enum": ["switching_friction", "proof_posture", "workflow_burden"]
        },
        "severity": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "statement": { "type": "string", "minLength": 10 },
        "question_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "source_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 2
        }
      }
    }
  }
}
