{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/program_increment_state.schema.json",
  "title": "ProductOS Program Increment State",
  "description": "A live state snapshot for a program increment or equivalent coordinated delivery window.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "program_increment_id",
    "workspace_id",
    "planning_model",
    "name",
    "status",
    "timebox",
    "objectives",
    "team_commitments",
    "dependency_health",
    "risk_summary",
    "last_updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "program_increment_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "planning_model": {
      "type": "string",
      "enum": [
        "safe_program_increment",
        "multi_team_increment",
        "custom"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "planning",
        "committed",
        "in_progress",
        "at_risk",
        "replanning",
        "completed"
      ]
    },
    "timebox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_date",
        "end_date"
      ],
      "properties": {
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "end_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "objectives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objective"
      },
      "minItems": 1
    },
    "team_commitments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/teamCommitment"
      },
      "minItems": 1
    },
    "dependency_health": {
      "type": "string",
      "enum": [
        "healthy",
        "watch",
        "at_risk",
        "blocked"
      ]
    },
    "risk_summary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      },
      "default": []
    },
    "inspect_adapt_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionItem"
      },
      "default": []
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective_id",
        "statement",
        "business_value",
        "status"
      ],
      "properties": {
        "objective_id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 5
        },
        "business_value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "at_risk",
            "done",
            "missed"
          ]
        }
      }
    },
    "teamCommitment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "team_name",
        "commitment_summary",
        "status"
      ],
      "properties": {
        "team_name": {
          "type": "string",
          "minLength": 1
        },
        "commitment_summary": {
          "type": "string",
          "minLength": 5
        },
        "status": {
          "type": "string",
          "enum": [
            "on_track",
            "watch",
            "at_risk",
            "blocked"
          ]
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "severity",
        "mitigation"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },
        "mitigation": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "actionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "owner",
        "due_date"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 5
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "due_date": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
