{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/artifact_version_metadata.schema.json",
  "title": "ProductOS Artifact Version Metadata",
  "description": "Metadata describing a versioned artifact revision and its approval state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version_id",
    "artifact_id",
    "artifact_type",
    "workspace_id",
    "version_number",
    "status",
    "created_at",
    "created_by",
    "change_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "version_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "version_number": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "blocked",
        "review_needed",
        "decision_ready",
        "approved",
        "superseded",
        "archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_by": {
      "type": "string"
    },
    "parent_version_id": {
      "type": "string"
    },
    "change_summary": {
      "type": "string",
      "minLength": 5
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "workflow_state_id": {
      "type": "string"
    }
  }
}
