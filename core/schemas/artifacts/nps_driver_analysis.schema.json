{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/nps_driver_analysis.schema.json",
  "title": "ProductOS Nps Driver Analysis",
  "description": "NPS driver correlation analysis — identifies what factors correlate with Promoter and Detractor scores.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "nps_driver_analysis_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "nps_driver_analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}