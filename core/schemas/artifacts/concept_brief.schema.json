{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/concept_brief.schema.json",
  "title": "ProductOS Concept Brief",
  "description": "Sharper framing of an idea into a concept with explicit segment and persona targeting.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "concept_brief_id",
    "workspace_id",
    "title",
    "hypothesis",
    "positioning_hypothesis",
    "offering_hypothesis",
    "wedge_hypothesis",
    "why_now",
    "why_us",
    "advantage_hypothesis",
    "status",
    "idea_record_ids",
    "strategy_artifact_ids",
    "target_segment_refs",
    "target_persona_refs",
    "canonical_persona_archetype_pack_id",
    "artifact_trace_map_id",
    "ralph_status",
    "prioritization",
    "must_be_true_assumptions",
    "risk_summary",
    "handoff_readiness_summary",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1.0" },
    "concept_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "hypothesis": { "type": "string", "minLength": 10 },
    "positioning_hypothesis": { "type": "string", "minLength": 10 },
    "offering_hypothesis": { "type": "string", "minLength": 10 },
    "wedge_hypothesis": { "type": "string", "minLength": 10 },
    "why_now": { "type": "string", "minLength": 10 },
    "why_us": { "type": "string", "minLength": 10 },
    "advantage_hypothesis": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["draft", "candidate", "validated", "parked"]
    },
    "idea_record_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "strategy_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "target_segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "target_persona_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "canonical_persona_archetype_pack_id": { "type": "string", "minLength": 1 },
    "artifact_trace_map_id": { "type": "string", "minLength": 1 },
    "ralph_status": {
      "type": "string",
      "enum": ["blocked", "review_needed", "decision_ready"]
    },
    "prioritization": { "$ref": "#/$defs/prioritization" },
    "linked_entity_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "default": []
    },
    "must_be_true_assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "risk_summary": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "handoff_readiness_summary": { "type": "string", "minLength": 10 },
    "uncertainty_map_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "prioritization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "priority_score", "confidence", "agentic_delivery_burden", "priority_rationale", "reviewer_handoff"],
      "properties": {
        "lane": {
          "type": "string",
          "enum": ["must_now", "next", "later", "park"]
        },
        "priority_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "agentic_delivery_burden": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "priority_rationale": { "type": "string", "minLength": 10 },
        "reviewer_handoff": { "type": "string", "minLength": 10 }
      }
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
