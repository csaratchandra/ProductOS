{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/outcome_review.schema.json",
  "title": "ProductOS Outcome Review",
  "description": "Assesses whether a released or adopted V4 change delivered the intended outcome and whether the path should be kept, iterated, or rolled back.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "outcome_review_id",
    "workspace_id",
    "reviewed_change_ref",
    "review_scope",
    "status",
    "pm_benchmark_ref",
    "ai_agent_benchmark_ref",
    "evidence_refs",
    "target_outcomes",
    "claim_verification_summary",
    "adoption_notes",
    "unresolved_pain_points",
    "support_signals",
    "adoption_signals",
    "reopen_recommendations",
    "rejected_path_updates",
    "next_action",
    "reviewed_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "outcome_review_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_change_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_scope": {
      "type": "string",
      "minLength": 10
    },
    "status": {
      "type": "string",
      "enum": [
        "tracking",
        "keep",
        "iterate",
        "rollback"
      ]
    },
    "pm_benchmark_ref": {
      "type": "string",
      "minLength": 1
    },
    "ai_agent_benchmark_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "target_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/targetOutcome"
      },
      "minItems": 1
    },
    "claim_verification_summary": {
      "type": "string",
      "minLength": 10
    },
    "adoption_notes": {
      "$ref": "#/$defs/stringList"
    },
    "unresolved_pain_points": {
      "$ref": "#/$defs/stringList"
    },
    "support_signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      },
      "minItems": 1
    },
    "adoption_signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      },
      "minItems": 1
    },
    "reopen_recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reopenRecommendation"
      },
      "minItems": 1
    },
    "rejected_path_updates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 10
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "targetOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome_name",
        "expected_signal",
        "observed_signal",
        "status"
      ],
      "properties": {
        "outcome_name": {
          "type": "string",
          "minLength": 3
        },
        "expected_signal": {
          "type": "string",
          "minLength": 10
        },
        "observed_signal": {
          "type": "string",
          "minLength": 10
        },
        "status": {
          "type": "string",
          "enum": [
            "met",
            "partial",
            "missed"
          ]
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_name", "summary", "direction", "evidence_refs"],
      "properties": {
        "signal_name": {
          "type": "string",
          "minLength": 3
        },
        "summary": {
          "type": "string",
          "minLength": 10
        },
        "direction": {
          "type": "string",
          "enum": ["improving", "stable", "declining"]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "reopenRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "recommended_action", "rationale", "evidence_refs"],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "problem_brief",
            "concept_brief",
            "prd",
            "opportunity_portfolio_view",
            "prioritization_decision_record",
            "feature_prioritization_brief"
          ]
        },
        "recommended_action": {
          "type": "string",
          "enum": ["review", "refresh", "reopen"]
        },
        "rationale": {
          "type": "string",
          "minLength": 10
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    }
  }
}
