{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/rollout_strategy.schema.json",
  "title": "ProductOS Rollout Strategy",
  "description": "Feature rollout and release strategy — feature flags, percentage rollout, beta groups, monitoring plan, and rollback procedures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rollout_strategy_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "rollout_strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}