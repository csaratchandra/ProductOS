{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/market_simulation_result.schema.json",
  "title": "ProductOS Market Simulation Result",
  "description": "Market-aware simulation result extending predictive simulation with competitive response, regulatory timing, economic sensitivity, and risk-adjusted roadmap.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "market_simulation_id", "architecture_ref", "competitive_response", "regulatory_timing", "risk_adjusted_roadmap", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "market_simulation_id": { "type": "string", "minLength": 1 },
    "architecture_ref": { "type": "string", "minLength": 1 },
    "competitive_response": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario", "adoption_impact", "confidence"],
        "properties": {
          "scenario": { "type": "string", "minLength": 1 },
          "adoption_impact": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "regulatory_timing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["regulation", "expected_date", "impact"],
        "properties": {
          "regulation": { "type": "string", "minLength": 1 },
          "expected_date": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "economic_sensitivity": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "factor": { "type": "string" },
          "impact": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "risk_adjusted_roadmap": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recommendation", "rationale"],
        "properties": {
          "recommendation": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
