{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/persona_archetype_pack.schema.json",
  "title": "ProductOS Persona Archetype Pack",
  "description": "Persona pack with explicit archetype roles, influence patterns, workflow traits, and canonical downstream truth for execution-driving artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "persona_archetype_pack_id",
    "workspace_id",
    "title",
    "segment_refs",
    "archetype_mode",
    "canonical_truth",
    "prioritization_basis",
    "archetypes",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1.0" },
    "persona_archetype_pack_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "archetype_mode": {
      "type": "string",
      "enum": ["buyer", "user", "champion", "blocker", "operator", "executive", "influencer"]
    },
    "canonical_truth": { "type": "boolean", "const": true },
    "prioritization_basis": { "$ref": "#/$defs/prioritizationBasis" },
    "archetypes": {
      "type": "array",
      "items": { "$ref": "#/$defs/archetype" },
      "minItems": 1
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "prioritizationBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "selection_rationale", "decision_owner"],
      "properties": {
        "lane": {
          "type": "string",
          "enum": ["must_now", "next", "later", "park"]
        },
        "selection_rationale": { "type": "string", "minLength": 10 },
        "decision_owner": { "type": "string", "minLength": 2 }
      }
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    },
    "archetype": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona_ref",
        "archetype_type",
        "role_summary",
        "goals",
        "pains",
        "triggers",
        "blockers",
        "buying_influence",
        "workflow_traits",
        "priority_score",
        "priority_rationale",
        "handoff_preferences",
        "evidence_refs"
      ],
      "properties": {
        "persona_ref": { "$ref": "#/$defs/entityRef" },
        "archetype_type": {
          "type": "string",
          "enum": ["buyer", "user", "champion", "blocker", "operator", "executive", "influencer"]
        },
        "role_summary": { "type": "string", "minLength": 10 },
        "goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "pains": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "triggers": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "buying_influence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "workflow_traits": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "priority_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "priority_rationale": { "type": "string", "minLength": 10 },
        "handoff_preferences": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "evidence_confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
}
