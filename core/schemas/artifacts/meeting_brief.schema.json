{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/meeting_brief.schema.json",
  "title": "ProductOS Meeting Brief",
  "description": "Stakeholder meeting preparation brief — audience, key messages, likely objections, decision needed, recommended approach.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_brief_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "meeting_brief_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}