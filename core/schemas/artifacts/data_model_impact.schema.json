{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/data_model_impact.schema.json",
  "title": "ProductOS Data Model Impact",
  "description": "Analysis of how new features impact the data model — new entities, fields, relationships, migrations, and backward compatibility.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "data_model_impact_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "data_model_impact_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}