{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/suite_registration.schema.json",
  "title": "ProductOS Suite Registration",
  "description": "Registry record describing a suite and its adopted ProductOS Core version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registration_id",
    "suite_id",
    "suite_name",
    "current_core_version",
    "workspace_ids",
    "registered_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "registration_id": {
      "type": "string",
      "minLength": 1
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "suite_name": {
      "type": "string",
      "minLength": 3
    },
    "current_core_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "workspace_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
