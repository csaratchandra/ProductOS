{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/cohort_analysis.schema.json",
  "title": "ProductOS Cohort Analysis",
  "description": "User cohort retention and behavior analysis — weekly cohorts, retention curves, feature adoption by cohort, trend indicators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cohort_analysis_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "cohort_analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}