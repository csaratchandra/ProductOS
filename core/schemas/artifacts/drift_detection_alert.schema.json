{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/drift_detection_alert.schema.json",
  "title": "ProductOS Drift Detection Alert",
  "description": "Alert generated when changed conditions cause artifact drift — identifying the source change, affected artifacts, drift severity, downstream impact propagation chain, and recommended refresh actions with urgency scoring.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "drift_alert_id", "workspace_id", "source_change_ref", "drifted_artifact_id", "drift_severity", "affected_downstream", "recommended_action", "detected_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "drift_alert_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "source_change_ref": {"type": "string", "minLength": 1},
    "drifted_artifact_id": {"type": "string", "minLength": 1},
    "drift_severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
    "drift_description": {"type": "string", "minLength": 10},
    "affected_downstream": {"type": "array", "items": {"$ref": "#/$defs/affectedArtifact"}, "minItems": 1},
    "recommended_action": {"type": "string", "minLength": 10},
    "auto_regenerate_scope": {"type": "string", "enum": ["full_artifact", "targeted_fields", "downstream_propagation", "pm_review_first"]},
    "detected_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "affectedArtifact": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "artifact_type", "impact", "refresh_priority"], "properties": {"artifact_id": {"type": "string", "minLength": 1}, "artifact_type": {"type": "string", "minLength": 3}, "impact": {"type": "string", "minLength": 10}, "refresh_priority": {"type": "string", "enum": ["must_now", "next", "later"]}}}
  }
}