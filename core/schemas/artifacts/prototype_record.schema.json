{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prototype_record.schema.json",
  "title": "ProductOS Prototype Record",
  "description": "Record of a prototype used to reduce ambiguity before PRD commitment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prototype_record_id",
    "workspace_id",
    "concept_brief_id",
    "title",
    "prototype_type",
    "prototype_fidelity",
    "interaction_depth",
    "objective",
    "uncertainty_statement",
    "primary_test_scenario",
    "experience_quality_target",
    "status",
    "target_segment_refs",
    "target_persona_refs",
    "validation_focus",
    "tested_assumptions",
    "proof_generated",
    "improvement_actions",
    "strategic_implication",
    "evaluated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "prototype_record_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "concept_brief_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "prototype_type": {
      "type": "string",
      "enum": ["doc", "wireframe", "mockup", "clickthrough", "service_simulation", "other"]
    },
    "prototype_fidelity": {
      "type": "string",
      "enum": ["low", "medium", "high", "v1_candidate"]
    },
    "interaction_depth": {
      "type": "string",
      "enum": ["static", "clickthrough", "interactive", "service_simulation"]
    },
    "objective": { "type": "string", "minLength": 10 },
    "uncertainty_statement": { "type": "string", "minLength": 10 },
    "primary_test_scenario": { "type": "string", "minLength": 10 },
    "experience_quality_target": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["planned", "in_test", "validated", "invalidated", "inconclusive"]
    },
    "target_segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "target_persona_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "validation_focus": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["usability", "feasibility", "trust", "workflow_fit", "clarity", "other"]
      },
      "minItems": 1
    },
    "tested_assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "proof_generated": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "quality_reference_examples": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "default": []
    },
    "positioning_signal": {
      "type": "string",
      "enum": ["positive", "mixed", "negative", "unknown"]
    },
    "buying_signal": {
      "type": "string",
      "enum": ["positive", "mixed", "negative", "unknown"]
    },
    "workflow_adoption_signal": {
      "type": "string",
      "enum": ["positive", "mixed", "negative", "unknown"]
    },
    "displacement_signal": {
      "type": "string",
      "enum": ["positive", "mixed", "negative", "unknown"]
    },
    "learnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "improvement_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "strategic_implication": { "type": "string", "minLength": 10 },
    "recommendation": {
      "type": "string",
      "enum": ["advance_to_problem_brief", "iterate", "park", "stop"]
    },
    "evaluated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
