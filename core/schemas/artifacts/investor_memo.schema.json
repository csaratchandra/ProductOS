{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/investor_memo.schema.json",
  "title": "ProductOS Investor Memo",
  "description": "Structured investor memorandum — Executive Summary, Problem, Solution, Market Opportunity, Competitive Advantage, Go-to-Market, Traction, Team, Financial Projections, Use of Funds, Key Risks — written in investment-grade language with evidence citations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "investor_memo_id", "workspace_id", "company_name", "executive_summary", "sections", "generated_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "investor_memo_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "company_name": {"type": "string", "minLength": 3},
    "executive_summary": {"type": "string", "minLength": 100},
    "sections": {"type": "array", "items": {"$ref": "#/$defs/section"}, "minItems": 6},
    "source_evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "default": []},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "section": {"type": "object", "additionalProperties": false, "required": ["title", "content", "key_claims"], "properties": {"title": {"type": "string", "minLength": 3}, "content": {"type": "string", "minLength": 50}, "key_claims": {"type": "array", "items": {"type": "string", "minLength": 10}, "minItems": 1}}}
  }
}