{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/design_token_set.schema.json",
  "title": "ProductOS Design Token Set",
  "description": "Reusable design system tokens for generated prototypes — colors, typography, spacing, shadows, border radii, and component primitives shared across all prototype variants for visual consistency.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "design_token_set_id", "workspace_id", "name", "colors", "typography", "spacing", "shadows", "radii", "generated_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "design_token_set_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 3},
    "colors": {
      "type": "object",
      "required": ["primary", "secondary", "neutral", "semantic"],
      "properties": {
        "primary": {"type": "object", "required": ["base", "light", "dark"], "properties": {"base": {"type": "string"}, "light": {"type": "string"}, "dark": {"type": "string"}}},
        "secondary": {"type": "object", "required": ["base", "light"], "properties": {"base": {"type": "string"}, "light": {"type": "string"}}},
        "neutral": {"type": "object", "required": ["white", "50", "100", "200", "300", "500", "700", "900"], "properties": {"white": {"type": "string"}, "50": {"type": "string"}, "100": {"type": "string"}, "200": {"type": "string"}, "300": {"type": "string"}, "500": {"type": "string"}, "700": {"type": "string"}, "900": {"type": "string"}}},
        "semantic": {"type": "object", "required": ["success", "warning", "error", "info"], "properties": {"success": {"type": "string"}, "warning": {"type": "string"}, "error": {"type": "string"}, "info": {"type": "string"}}}
      }
    },
    "typography": {
      "type": "object",
      "required": ["font_family", "scale"],
      "properties": {
        "font_family": {"type": "string"},
        "scale": {"type": "object", "required": ["h1", "h2", "h3", "body", "small", "caption"], "properties": {"h1": {"type": "string"}, "h2": {"type": "string"}, "h3": {"type": "string"}, "body": {"type": "string"}, "small": {"type": "string"}, "caption": {"type": "string"}}}
      }
    },
    "spacing": {"type": "object", "required": ["xs", "sm", "md", "lg", "xl", "2xl"], "properties": {"xs": {"type": "string"}, "sm": {"type": "string"}, "md": {"type": "string"}, "lg": {"type": "string"}, "xl": {"type": "string"}, "2xl": {"type": "string"}}},
    "shadows": {"type": "object", "required": ["sm", "md", "lg"], "properties": {"sm": {"type": "string"}, "md": {"type": "string"}, "lg": {"type": "string"}}},
    "radii": {"type": "object", "required": ["sm", "md", "lg", "full"], "properties": {"sm": {"type": "string"}, "md": {"type": "string"}, "lg": {"type": "string"}, "full": {"type": "string"}}},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}