{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/feature_portfolio_review.schema.json",
  "title": "ProductOS Feature Portfolio Review",
  "description": "Portfolio-level review summarizing the current score and next action for the major ProductOS superpower slices.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "feature_portfolio_review_id",
    "workspace_id",
    "review_scope",
    "benchmark_ref",
    "adapter_registry_ref",
    "truthfulness_status",
    "eval_run_ref",
    "feature_summaries",
    "top_priority_feature_id",
    "promoted_feature_ids",
    "internal_use_feature_ids",
    "active_improvement_feature_ids",
    "blocked_feature_ids",
    "next_action",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "feature_portfolio_review_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "review_scope": {
      "type": "string",
      "minLength": 10
    },
    "benchmark_ref": {
      "type": "string",
      "minLength": 1
    },
    "adapter_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "truthfulness_status": {
      "type": "string",
      "enum": [
        "healthy",
        "watch",
        "blocked"
      ]
    },
    "eval_run_ref": {
      "type": "string",
      "minLength": 1
    },
    "scorecard_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "feature_summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/featureSummary"
      },
      "minItems": 1
    },
    "top_priority_feature_id": {
      "type": "string",
      "minLength": 1
    },
    "promoted_feature_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "internal_use_feature_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "active_improvement_feature_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_feature_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "highlighted_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "next_action": {
      "type": "string",
      "minLength": 10
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "featureSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_id",
        "feature_name",
        "loop_id",
        "overall_score",
        "adoption_recommendation",
        "gap_summary",
        "provenance_classification",
        "next_action"
      ],
      "properties": {
        "feature_id": {
          "type": "string",
          "minLength": 1
        },
        "feature_name": {
          "type": "string",
          "minLength": 3
        },
        "loop_id": {
          "type": "string",
          "enum": [
            "signal_to_product_decision",
            "decision_to_stakeholder_alignment",
            "feedback_to_accepted_improvement",
            "cross_cutting"
          ]
        },
        "scorecard_ref": {
          "type": "string"
        },
        "overall_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "adoption_recommendation": {
          "type": "string",
          "enum": [
            "promote_as_standard",
            "keep_in_internal_use",
            "route_to_improvement",
            "block"
          ]
        },
        "gap_summary": {
          "type": "string",
          "minLength": 10
        },
        "provenance_classification": {
          "type": "string",
          "enum": [
            "real",
            "seeded",
            "mixed"
          ]
        },
        "next_action": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
