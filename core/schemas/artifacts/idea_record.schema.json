{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/idea_record.schema.json",
  "title": "ProductOS Idea Record",
  "description": "Raw opportunity or solution idea linked to target segment and persona context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "idea_record_id",
    "workspace_id",
    "title",
    "summary",
    "status",
    "target_segment_refs",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "idea_record_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "summary": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["captured", "triaged", "selected", "rejected", "parked"]
    },
    "source_type": {
      "type": "string",
      "enum": ["pm_observation", "customer_feedback", "support_signal", "stakeholder_request", "research", "other"]
    },
    "target_segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "target_persona_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "default": []
    },
    "linked_entity_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
