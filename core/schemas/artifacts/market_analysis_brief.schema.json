{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/market_analysis_brief.schema.json",
  "title": "ProductOS Market Analysis Brief",
  "description": "Structured market analysis covering trends, dynamics, dependencies, and risks beyond sizing math.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "market_analysis_brief_id",
    "workspace_id",
    "title",
    "market_name",
    "category_structure",
    "category_summary",
    "trend_summary",
    "market_dynamics",
    "power_centers",
    "adoption_barriers",
    "switching_costs",
    "market_role_implications",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "market_analysis_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "market_name": { "type": "string", "minLength": 3 },
    "research_scope": { "type": "string", "minLength": 5 },
    "category_structure": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "category_summary": { "type": "string", "minLength": 10 },
    "trend_summary": { "type": "string", "minLength": 10 },
    "market_dynamics": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "power_centers": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "adoption_barriers": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "switching_costs": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "market_role_implications": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "ecosystem_dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "regulatory_considerations": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "moat_pressures": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "key_uncertainties": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "feature_shifts": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "agentic_market_signals": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "source_note_card_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "last_refreshed_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
