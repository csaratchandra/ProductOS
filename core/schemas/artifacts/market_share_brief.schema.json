{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/market_share_brief.schema.json",
  "title": "ProductOS Market Share Brief",
  "description": "Structured market share view with explicit scope, basis, timeframe, and confidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "market_share_brief_id",
    "workspace_id",
    "title",
    "market_name",
    "share_type",
    "timeframe",
    "denominator",
    "estimates",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "market_share_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "market_name": { "type": "string", "minLength": 3 },
    "share_type": {
      "type": "string",
      "enum": ["current_share", "reachable_share", "segment_share", "share_shift_signal"]
    },
    "timeframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      }
    },
    "denominator": { "type": "string", "minLength": 5 },
    "estimates": {
      "type": "array",
      "items": { "$ref": "#/$defs/estimate" },
      "minItems": 1
    },
    "sensitivity_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_name",
        "share_percent",
        "confidence",
        "basis",
        "source_refs"
      ],
      "properties": {
        "subject_name": { "type": "string", "minLength": 2 },
        "subject_type": {
          "type": "string",
          "enum": ["company", "segment", "product", "category"],
          "default": "company"
        },
        "share_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "basis": { "type": "string", "minLength": 10 },
        "source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
}
