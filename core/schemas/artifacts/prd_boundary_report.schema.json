{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prd_boundary_report.schema.json",
  "title": "ProductOS PRD Boundary Report",
  "description": "Reports on PRD scope boundary quality with scoring, flagged items, and suggested fixes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prd_boundary_report_id",
    "workspace_id",
    "prd_ref",
    "score",
    "specificity_score",
    "coverage_score",
    "alignment_score",
    "flagged_boundaries",
    "suggested_fixes",
    "approval_status",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "prd_boundary_report_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "prd_ref": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "specificity_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "coverage_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "alignment_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "flagged_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["boundary_text", "flag_reason", "severity"],
        "properties": {
          "boundary_text": {
            "type": "string",
            "minLength": 1
          },
          "flag_reason": {
            "type": "string",
            "minLength": 3
          },
          "severity": {
            "type": "string",
            "enum": ["minor", "moderate", "critical"]
          },
          "suggested_replacement": {
            "type": "string"
          }
        }
      }
    },
    "suggested_fixes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "approval_status": {
      "type": "string",
      "enum": ["approved", "needs_revision", "blocked"]
    },
    "maturity_band": {
      "type": "string",
      "enum": ["zero_to_one", "one_to_ten", "ten_to_hundred", "hundred_to_thousand_plus"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
