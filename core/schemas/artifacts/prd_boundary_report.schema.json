{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prd_boundary_report.schema.json",
  "title": "ProductOS PRD Boundary Report",
  "description": "Deterministic report validating whether PRD out-of-scope boundaries are explicit enough for downstream execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prd_boundary_report_id",
    "workspace_id",
    "prd_ref",
    "score",
    "score_breakdown",
    "flagged_boundaries",
    "suggested_fixes",
    "approval_status",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "prd_boundary_report_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "prd_ref": { "type": "string", "minLength": 1 },
    "score": { "type": "number", "minimum": 0, "maximum": 10 },
    "score_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specificity", "coverage", "alignment"],
      "properties": {
        "specificity": { "type": "number", "minimum": 0, "maximum": 10 },
        "coverage": { "type": "number", "minimum": 0, "maximum": 10 },
        "alignment": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },
    "flagged_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["boundary", "issue", "suggested_fix"],
        "properties": {
          "boundary": { "type": "string", "minLength": 1 },
          "issue": { "type": "string", "minLength": 1 },
          "suggested_fix": { "type": "string", "minLength": 1 }
        }
      }
    },
    "suggested_fixes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approval_status": {
      "type": "string",
      "enum": ["approved", "needs_revision", "blocked"]
    },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
