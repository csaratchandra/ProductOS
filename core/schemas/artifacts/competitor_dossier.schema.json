{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/competitor_dossier.schema.json",
  "title": "ProductOS Competitor Dossier",
  "description": "Structured summary of competitor context relevant to a segment, persona, and problem space.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "competitor_dossier_id",
    "workspace_id",
    "title",
    "competitive_frame",
    "comparison_basis",
    "framework_registry_ref",
    "selected_framework_ids",
    "target_segment_refs",
    "target_persona_refs",
    "source_artifact_ids",
    "status_quo_alternatives",
    "internal_build_risk",
    "competitive_landscape_status",
    "evidence_coverage_status",
    "dossier_quality",
    "named_competitor_count",
    "where_we_win",
    "where_we_lose",
    "credible_wedge_for_posture",
    "required_proof_to_displace",
    "prioritization_implications",
    "competitors",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "competitor_dossier_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "competitive_frame": {
      "type": "string",
      "minLength": 10
    },
    "comparison_basis": {
      "type": "string",
      "minLength": 10
    },
    "framework_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "selected_framework_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "research_scope": {
      "type": "string",
      "minLength": 5
    },
    "target_segment_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityRef"
      },
      "minItems": 1
    },
    "target_persona_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityRef"
      },
      "minItems": 1
    },
    "linked_entity_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityRef"
      },
      "default": []
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "status_quo_alternatives": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "internal_build_risk": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "competitive_landscape_status": {
      "type": "string",
      "enum": ["abstract_alternatives_only", "named_competitor_set"]
    },
    "evidence_coverage_status": {
      "type": "string",
      "enum": ["internal_only", "partial_external", "triangulated_external"]
    },
    "dossier_quality": {
      "type": "string",
      "enum": ["draft", "reviewable", "decision_ready"]
    },
    "named_competitor_count": {
      "type": "integer",
      "minimum": 0
    },
    "where_we_win": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 1
    },
    "where_we_lose": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 1
    },
    "credible_wedge_for_posture": {
      "type": "string",
      "minLength": 10
    },
    "required_proof_to_displace": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 1
    },
    "prioritization_implications": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 1
    },
    "recommended_positioning_angle": {
      "type": "string",
      "minLength": 10
    },
    "feature_taxonomy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "competitors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/competitor"
      },
      "minItems": 1
    },
    "last_refreshed_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "competitor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "competitor_type",
        "target_customer",
        "positioning_summary",
        "go_to_market_motion",
        "pricing_signal",
        "positioning_gap",
        "strengths",
        "weaknesses",
        "where_they_win",
        "where_they_lose",
        "displacement_barriers",
        "implications",
        "evidence_refs",
        "confidence",
        "last_checked_at"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "category": {
          "type": "string",
          "enum": [
            "direct_pm_platform",
            "indirect_pm_platform",
            "adjacent_work_platform",
            "agentic_research_tool",
            "competitive_intelligence_tool"
          ]
        },
        "competitor_type": {
          "type": "string",
          "enum": ["direct", "indirect", "tech_platform", "vendor", "startup", "status_quo", "in_house"]
        },
        "target_customer": {
          "type": "string",
          "minLength": 5
        },
        "positioning_summary": {
          "type": "string",
          "minLength": 10
        },
        "go_to_market_motion": {
          "type": "string",
          "minLength": 5
        },
        "pricing_signal": {
          "type": "string",
          "minLength": 3
        },
        "positioning_gap": {
          "type": "string",
          "minLength": 10
        },
        "icp_overlap": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "substitution_risk": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "ecosystem_role": {
          "type": "string",
          "minLength": 5
        },
        "agentic_features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "default": []
        },
        "governance_features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "default": []
        },
        "capability_gaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "default": []
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "minItems": 1
        },
        "weaknesses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "minItems": 1
        },
        "where_they_win": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          },
          "minItems": 1
        },
        "where_they_lose": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          },
          "minItems": 1
        },
        "displacement_barriers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          },
          "minItems": 1
        },
        "implications": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          },
          "minItems": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "last_checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
