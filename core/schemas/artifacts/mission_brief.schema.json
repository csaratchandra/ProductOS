{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/mission_brief.schema.json",
  "title": "ProductOS Mission Brief",
  "description": "Canonical PM-first mission intake for a bounded ProductOS execution loop.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_brief_id",
    "workspace_id",
    "title",
    "mission_summary",
    "target_user",
    "customer_problem",
    "business_goal",
    "success_metrics",
    "constraints",
    "audience",
    "operating_mode",
    "primary_workflow_refs",
    "source_refs",
    "next_action",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "mission_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 5 },
    "mission_summary": { "type": "string", "minLength": 20 },
    "target_user": { "type": "string", "minLength": 3 },
    "customer_problem": { "type": "string", "minLength": 10 },
    "business_goal": { "type": "string", "minLength": 10 },
    "success_metrics": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "audience": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "operating_mode": {
      "type": "string",
      "enum": ["discover", "discover_to_align", "full_loop"]
    },
    "primary_workflow_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "minItems": 1
    },
    "next_action": { "type": "string", "minLength": 10 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
