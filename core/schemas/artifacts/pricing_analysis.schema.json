{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/pricing_analysis.schema.json",
  "title": "ProductOS Pricing Analysis",
  "description": "Comprehensive pricing intelligence artifact covering competitor pricing matrix, willingness-to-pay synthesis, pricing model options with pros/cons, unit economics per segment, price sensitivity analysis (Van Westendorp), and auto-generated ROI calculator specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "pricing_analysis_id", "workspace_id", "title",
    "target_segments", "analysis_date", "competitor_pricing", "willingness_to_pay",
    "pricing_model_options", "unit_economics", "recommendation"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "pricing_analysis_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 5 },
    "target_segments": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "analysis_date": { "type": "string", "format": "date-time" },
    "competitor_pricing": { "$ref": "#/$defs/competitorPricing" },
    "willingness_to_pay": { "$ref": "#/$defs/willingnessToPay" },
    "price_sensitivity": { "$ref": "#/$defs/priceSensitivity" },
    "pricing_model_options": { "$ref": "#/$defs/pricingModelOptions" },
    "unit_economics": { "$ref": "#/$defs/unitEconomics" },
    "roi_calculator_spec": { "$ref": "#/$defs/roiCalculatorSpec" },
    "recommendation": { "$ref": "#/$defs/pricingRecommendation" },
    "source_evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "competitorPricing": {
      "type": "object", "additionalProperties": false,
      "required": ["competitors", "comparison_summary"],
      "properties": {
        "competitors": { "type": "array", "items": { "$ref": "#/$defs/competitorPricingEntry" }, "minItems": 1 },
        "comparison_summary": { "type": "string", "minLength": 10 }
      }
    },
    "competitorPricingEntry": {
      "type": "object", "additionalProperties": false,
      "required": ["competitor_id", "competitor_name", "tiers", "pricing_model_type"],
      "properties": {
        "competitor_id": { "type": "string", "minLength": 1 },
        "competitor_name": { "type": "string", "minLength": 2 },
        "pricing_model_type": { "type": "string", "enum": ["subscription_per_seat", "usage_based", "tiered_flat", "freemium", "custom_quote", "hybrid", "open_source_free"] },
        "tiers": { "type": "array", "items": { "$ref": "#/$defs/pricingTier" }, "minItems": 1 },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    },
    "pricingTier": {
      "type": "object", "additionalProperties": false,
      "required": ["tier_name", "price_amount", "price_unit", "features_included"],
      "properties": {
        "tier_name": { "type": "string", "minLength": 3 },
        "price_amount": { "type": "number", "minimum": 0 },
        "price_unit": { "type": "string", "enum": ["per_month_per_user", "per_month_flat", "per_usage_unit", "annual_flat", "custom"] },
        "features_included": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
        "features_excluded": { "type": "array", "items": { "type": "string", "minLength": 3 }, "default": [] }
      }
    },
    "willingnessToPay": {
      "type": "object", "additionalProperties": false,
      "required": ["per_segment", "synthesis_method", "confidence"],
      "properties": {
        "per_segment": { "type": "array", "items": { "$ref": "#/$defs/segmentWTP" }, "minItems": 1 },
        "synthesis_method": { "type": "string", "minLength": 10 },
        "confidence": { "type": "string", "enum": ["high", "moderate", "low"] }
      }
    },
    "segmentWTP": {
      "type": "object", "additionalProperties": false,
      "required": ["segment_id", "segment_name", "wtp_range_low", "wtp_range_high", "median_wtp", "price_elasticity"],
      "properties": {
        "segment_id": { "type": "string", "minLength": 1 },
        "segment_name": { "type": "string", "minLength": 2 },
        "wtp_range_low": { "type": "number", "minimum": 0 },
        "wtp_range_high": { "type": "number", "minimum": 0 },
        "median_wtp": { "type": "number", "minimum": 0 },
        "price_elasticity": { "type": "string", "enum": ["elastic", "moderately_elastic", "inelastic"] },
        "evidence_basis": { "type": "string", "minLength": 10 }
      }
    },
    "priceSensitivity": {
      "type": "object", "additionalProperties": false,
      "required": ["method", "findings", "optimal_price_point"],
      "properties": {
        "method": { "type": "string", "enum": ["van_westendorp", "gabor_granger", "conjoint", "research_synthesis", "competitor_benchmark"] },
        "findings": { "$ref": "#/$defs/vanWestendorp" },
        "optimal_price_point": { "type": "number", "minimum": 0 }
      }
    },
    "vanWestendorp": {
      "type": "object", "additionalProperties": false,
      "required": ["too_expensive", "expensive", "bargain", "too_cheap"],
      "properties": {
        "too_expensive": { "type": "number" },
        "expensive": { "type": "number" },
        "bargain": { "type": "number" },
        "too_cheap": { "type": "number" }
      }
    },
    "pricingModelOptions": {
      "type": "object", "additionalProperties": false,
      "required": ["models", "recommended_model"],
      "properties": {
        "models": { "type": "array", "items": { "$ref": "#/$defs/pricingModel" }, "minItems": 2 },
        "recommended_model": { "type": "string", "minLength": 3 }
      }
    },
    "pricingModel": {
      "type": "object", "additionalProperties": false,
      "required": ["model_id", "model_name", "model_type", "pros", "cons", "best_for", "revenue_projection_annual"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "model_name": { "type": "string", "minLength": 3 },
        "model_type": { "type": "string", "enum": ["pure_subscription", "usage_based", "hybrid", "freemium", "tiered_per_seat", "per_active_user", "platform_fee", "custom"] },
        "pros": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 2 },
        "cons": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 2 },
        "best_for": { "type": "string", "minLength": 10 },
        "revenue_projection_annual": { "type": "number", "minimum": 0 },
        "pricing_tiers": { "type": "array", "items": { "$ref": "#/$defs/pricingTier" }, "default": [] }
      }
    },
    "unitEconomics": {
      "type": "object", "additionalProperties": false,
      "required": ["per_segment"],
      "properties": {
        "per_segment": { "type": "array", "items": { "$ref": "#/$defs/segmentUnitEconomics" }, "minItems": 1 }
      }
    },
    "segmentUnitEconomics": {
      "type": "object", "additionalProperties": false,
      "required": ["segment_id", "cac", "ltv", "ltv_cac_ratio", "payback_period_months", "gross_margin_pct", "assessment"],
      "properties": {
        "segment_id": { "type": "string", "minLength": 1 },
        "cac": { "type": "number", "minimum": 0 },
        "ltv": { "type": "number", "minimum": 0 },
        "ltv_cac_ratio": { "type": "number", "minimum": 0 },
        "payback_period_months": { "type": "number", "minimum": 0 },
        "gross_margin_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "assessment": { "type": "string", "enum": ["healthy", "breakeven", "unprofitable", "insufficient_data"] }
      }
    },
    "roiCalculatorSpec": {
      "type": "object", "additionalProperties": false,
      "required": ["title", "inputs", "outputs", "value_proposition"],
      "properties": {
        "title": { "type": "string", "minLength": 5 },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/roiInput" }, "minItems": 2 },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/roiOutput" }, "minItems": 2 },
        "value_proposition": { "type": "string", "minLength": 10 }
      }
    },
    "roiInput": {
      "type": "object", "additionalProperties": false,
      "required": ["field", "label", "default_value", "description"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 3 },
        "default_value": { "type": "number" },
        "description": { "type": "string", "minLength": 5 }
      }
    },
    "roiOutput": {
      "type": "object", "additionalProperties": false,
      "required": ["label", "formula", "format"],
      "properties": {
        "label": { "type": "string", "minLength": 3 },
        "formula": { "type": "string", "minLength": 3 },
        "format": { "type": "string", "enum": ["currency", "percentage", "months", "number"] }
      }
    },
    "pricingRecommendation": {
      "type": "object", "additionalProperties": false,
      "required": ["recommended_model_id", "recommended_starting_price", "rationale", "risks", "next_steps"],
      "properties": {
        "recommended_model_id": { "type": "string", "minLength": 1 },
        "recommended_starting_price": { "type": "number", "minimum": 0 },
        "rationale": { "type": "string", "minLength": 10 },
        "risks": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 1 },
        "next_steps": { "type": "array", "items": { "type": "string", "minLength": 5 }, "minItems": 1 }
      }
    }
  }
}