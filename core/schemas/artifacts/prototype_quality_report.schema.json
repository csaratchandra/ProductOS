{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prototype_quality_report.schema.json",
  "title": "ProductOS Prototype Quality Report",
  "description": "Auto-scored prototype quality evaluation across all quality dimensions including visual, interaction, IA, accessibility, state completeness, and user test readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prototype_quality_report_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "prototype_quality_report_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}