{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prototype_annotation.schema.json",
  "title": "ProductOS Prototype Annotation",
  "description": "PM annotation layer for prototypes — click-to-note feedback capture with element targeting and downstream propagation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prototype_annotation_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "prototype_annotation_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}