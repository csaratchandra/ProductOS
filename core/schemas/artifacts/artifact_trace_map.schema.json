{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/artifact_trace_map.schema.json",
  "title": "ProductOS Artifact Trace Map",
  "description": "Captures how an artifact is linked to entities, evidence, and upstream artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_map_id",
    "workspace_id",
    "artifact_id",
    "artifact_type",
    "entity_links",
    "evidence_refs",
    "upstream_artifact_ids",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_map_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "minLength": 1
    },
    "entity_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityLink"
      },
      "minItems": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceRef"
      },
      "default": []
    },
    "upstream_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "change_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "entityLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "entity_id",
        "link_reason"
      ],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": [
            "segment",
            "persona",
            "problem",
            "outcome",
            "opportunity",
            "feature",
            "metric",
            "decision"
          ]
        },
        "entity_id": {
          "type": "string",
          "minLength": 1
        },
        "link_reason": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_id",
        "justification"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "meeting_record",
            "change_event",
            "status_mail",
            "issue_log",
            "transcript",
            "decision_log",
            "other"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "justification": {
          "type": "string",
          "minLength": 5
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshness_status": {
          "type": "string",
          "enum": [
            "fresh",
            "usable_with_review",
            "stale"
          ]
        },
        "claim_role": {
          "type": "string",
          "enum": [
            "direct_evidence",
            "supporting_context",
            "inference_boundary"
          ]
        }
      }
    }
  }
}
