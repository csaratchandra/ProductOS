{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/workspace_tree_state.schema.json",
  "title": "ProductOS Workspace Tree State",
  "description": "Canonical hierarchy for portfolio, workspace, mission, documents, and artifacts used by PM-facing cockpit surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_tree_state_id",
    "workspace_id",
    "portfolio_id",
    "root",
    "active_mission_ref",
    "active_product_record_ref",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workspace_tree_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "portfolio_id": {
      "type": "string",
      "minLength": 1
    },
    "root": {
      "$ref": "#/$defs/treeNode"
    },
    "active_mission_ref": {
      "type": "string",
      "minLength": 1
    },
    "active_product_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "treeNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type",
        "label",
        "children"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "type": "string",
          "enum": ["portfolio", "workspace", "mission", "collection", "document", "artifact"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/treeNode"
          }
        }
      }
    }
  }
}
