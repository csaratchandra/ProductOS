{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/segment_map.schema.json",
  "title": "ProductOS Segment Map",
  "description": "Structured segment view across an explicit segmentation lens with strategy-relevant evidence, posture fit, and solution entry points.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "segment_map_id",
    "workspace_id",
    "title",
    "market_name",
    "market_scope_summary",
    "segmentation_lens",
    "segmentation_logic",
    "segments",
    "recommended_beachhead_segment_id",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "segment_map_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "market_name": { "type": "string", "minLength": 3 },
    "market_scope_summary": { "type": "string", "minLength": 10 },
    "segmentation_lens": {
      "type": "string",
      "enum": [
        "firmographic",
        "behavioral",
        "workflow_maturity",
        "job_to_be_done",
        "adoption_readiness",
        "economic_value"
      ]
    },
    "segmentation_logic": { "type": "string", "minLength": 10 },
    "segments": {
      "type": "array",
      "items": { "$ref": "#/$defs/segment" },
      "minItems": 1
    },
    "recommended_beachhead_segment_id": { "type": "string", "minLength": 1 },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "postureFit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["posture", "fit", "rationale"],
      "properties": {
        "posture": {
          "type": "string",
          "enum": ["leader", "challenger", "follower", "niche"]
        },
        "fit": {
          "type": "string",
          "enum": ["strong", "viable", "weak"]
        },
        "rationale": { "type": "string", "minLength": 10 }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_id",
        "name",
        "definition",
        "qualifying_traits",
        "core_job",
        "struggle_moments",
        "primary_value_drivers",
        "buying_context",
        "adoption_constraints",
        "posture_fit",
        "best_fit_posture",
        "solution_entry_points",
        "confidence",
        "attractiveness",
        "urgency",
        "evidence_refs"
      ],
      "properties": {
        "segment_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 2 },
        "definition": { "type": "string", "minLength": 10 },
        "qualifying_traits": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "core_job": { "type": "string", "minLength": 10 },
        "struggle_moments": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "primary_value_drivers": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "buying_context": { "type": "string", "minLength": 10 },
        "adoption_constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "posture_fit": {
          "type": "array",
          "items": { "$ref": "#/$defs/postureFit" },
          "minItems": 1
        },
        "best_fit_posture": {
          "type": "string",
          "enum": ["leader", "challenger", "follower", "niche"]
        },
        "solution_entry_points": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "disqualifiers": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "default": []
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "attractiveness": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "urgency": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "counterevidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    }
  }
}
