{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/domain_activation.schema.json",
  "title": "ProductOS Domain Activation",
  "description": "Suggested domain packs, regions, and sub-packs with confidence scoring for automatic domain intelligence activation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "domain_activation_id",
    "decomposition_ref",
    "domain",
    "confidence",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "domain_activation_id": { "type": "string", "minLength": 1 },
    "decomposition_ref": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 2 },
    "sub_domains": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "regions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "sub_packs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "compatibility_notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
