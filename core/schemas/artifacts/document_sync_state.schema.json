{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/document_sync_state.schema.json",
  "title": "ProductOS Document Sync State",
  "description": "Tracks artifact-to-readable-doc generation, sync state, drift handling, and docs-first governance metadata for readable documents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_sync_state_id",
    "workspace_id",
    "sync_scope",
    "validation_tier",
    "status",
    "source_artifact_refs",
    "documents",
    "drift_summary",
    "review_requirements",
    "next_action",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "document_sync_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "sync_scope": {
      "type": "string",
      "minLength": 3
    },
    "validation_tier": {
      "type": "string",
      "enum": [
        "tier_1",
        "tier_2"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "in_sync",
        "review_pending",
        "drift_detected",
        "blocked"
      ]
    },
    "source_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/documentEntry"
      },
      "minItems": 1
    },
    "drift_summary": {
      "type": "string",
      "minLength": 10
    },
    "review_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 10
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      },
      "minItems": 1
    },
    "modificationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version_number", "updated_at", "updated_by", "summary"],
      "properties": {
        "version_number": {
          "type": "integer",
          "minimum": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_by": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "documentEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_key",
        "title",
        "readable_path",
        "source_artifact_refs",
        "audience",
        "status",
        "version_number",
        "modification_log",
        "last_sync_status"
      ],
      "properties": {
        "doc_key": {
          "type": "string",
          "minLength": 3
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "readable_path": {
          "type": "string",
          "minLength": 3
        },
        "source_artifact_refs": {
          "$ref": "#/$defs/stringList"
        },
        "audience": {
          "$ref": "#/$defs/stringList"
        },
        "status": {
          "type": "string",
          "enum": [
            "generated",
            "synced",
            "drifted",
            "review_pending"
          ]
        },
        "version_number": {
          "type": "integer",
          "minimum": 1
        },
        "modification_log": {
          "type": "array",
          "items": { "$ref": "#/$defs/modificationEntry" },
          "minItems": 1
        },
        "last_sync_status": {
          "type": "string",
          "minLength": 10
        },
        "auto_render_enabled": {
          "type": "boolean",
          "default": false
        },
        "template_ref": {
          "type": "string",
          "minLength": 1
        },
        "last_rendered_at": {
          "type": "string",
          "format": "date-time"
        },
        "render_trigger": {
          "type": "string",
          "enum": ["auto", "manual", "pm_note", "regeneration_queue"]
        }
      }
    }
  }
}
