{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/release_gate_decision.schema.json",
  "title": "ProductOS Release Gate Decision",
  "description": "Internal release-gate decision artifact that combines benchmark, scenario proof, and readiness evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_gate_decision_id",
    "workspace_id",
    "target_release",
    "decision",
    "pm_benchmark_ref",
    "runtime_scenario_report_ref",
    "release_readiness_ref",
    "rationale",
    "known_gaps",
    "deferred_items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "release_gate_decision_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "target_release": {
      "type": "string",
      "pattern": "^v\\d+_\\d+(?:_\\d+)?$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "go",
        "conditional_go",
        "no_go"
      ]
    },
    "pm_benchmark_ref": {
      "type": "string",
      "minLength": 1
    },
    "runtime_scenario_report_ref": {
      "type": "string",
      "minLength": 1
    },
    "release_readiness_ref": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 10
    },
    "next_action": {
      "type": "string"
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "deferred_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
