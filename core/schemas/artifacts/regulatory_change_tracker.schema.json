{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/regulatory_change_tracker.schema.json",
  "title": "ProductOS Regulatory Change Tracker",
  "description": "Tracks regulatory developments that may impact the product — proposed regulations, enacted legislation, compliance deadlines, jurisdictional scope, and impact on product features, data handling, and market access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "regulatory_change_tracker_id",
    "workspace_id",
    "status",
    "jurisdictions",
    "active_items",
    "upcoming_deadlines",
    "impact_summary",
    "last_reviewed_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "regulatory_change_tracker_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["current", "attention_needed", "critical"]
    },
    "jurisdictions": {
      "type": "array",
      "items": { "$ref": "#/$defs/jurisdiction" },
      "minItems": 1
    },
    "active_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/regulatoryItem" },
      "minItems": 1
    },
    "upcoming_deadlines": {
      "type": "array",
      "items": { "$ref": "#/$defs/deadline" },
      "default": []
    },
    "impact_summary": { "$ref": "#/$defs/impactSummary" },
    "source_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "last_reviewed_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "jurisdiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jurisdiction_id", "name", "regulatory_risk_level", "active_item_count"],
      "properties": {
        "jurisdiction_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 2 },
        "country_code": { "type": "string", "minLength": 2, "maxLength": 2 },
        "region": { "type": "string", "minLength": 2 },
        "regulatory_risk_level": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "active_item_count": { "type": "integer", "minimum": 0 }
      }
    },
    "regulatoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "title",
        "regulatory_body",
        "jurisdiction_id",
        "type",
        "status",
        "description",
        "product_impact",
        "confidence"
      ],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 5 },
        "regulatory_body": { "type": "string", "minLength": 3 },
        "jurisdiction_id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["proposed_regulation", "enacted_legislation", "court_ruling", "agency_guidance", "industry_standard", "trade_agreement", "executive_order", "ballot_measure", "other"]
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "under_review", "enacted", "effective", "challenged", "repealed", "delayed"]
        },
        "description": { "type": "string", "minLength": 20 },
        "product_impact": { "$ref": "#/$defs/productImpact" },
        "compliance_deadline": { "type": "string", "format": "date-time" },
        "probability_of_enactment": { "type": "integer", "minimum": 0, "maximum": 100 },
        "confidence": {
          "type": "string",
          "enum": ["high", "moderate", "low"]
        },
        "evidence_urls": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "detected_at": { "type": "string", "format": "date-time" },
        "last_updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "productImpact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "affected_capabilities", "action_required", "summary"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["blocker", "major", "moderate", "minor", "none"]
        },
        "affected_capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "action_required": {
          "type": "string",
          "enum": ["must_change_product", "add_compliance_feature", "update_documentation", "legal_review_needed", "monitor_only", "no_action"]
        },
        "summary": { "type": "string", "minLength": 10 },
        "affected_artifact_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "deadline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deadline_id", "item_id", "deadline_date", "description", "consequence_of_missing"],
      "properties": {
        "deadline_id": { "type": "string", "minLength": 1 },
        "item_id": { "type": "string", "minLength": 1 },
        "deadline_date": { "type": "string", "format": "date-time" },
        "description": { "type": "string", "minLength": 10 },
        "consequence_of_missing": { "type": "string", "minLength": 10 }
      }
    },
    "impactSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_count", "high_count", "total_active", "most_impacted_jurisdiction", "top_action_item"],
      "properties": {
        "critical_count": { "type": "integer", "minimum": 0 },
        "high_count": { "type": "integer", "minimum": 0 },
        "total_active": { "type": "integer", "minimum": 0 },
        "most_impacted_jurisdiction": { "type": "string", "minLength": 2 },
        "top_action_item": { "type": "string", "minLength": 10 }
      }
    }
  }
}