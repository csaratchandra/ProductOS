{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/corridor_proof_pack.schema.json",
  "title": "ProductOS Corridor Proof Pack",
  "description": "Proof register for a workflow corridor page with customer-safe filtering and claim coverage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "corridor_proof_pack_id",
    "workflow_corridor_spec_id",
    "workspace_id",
    "proof_summary",
    "claim_mode_counts",
    "claim_register",
    "proof_items",
    "proof_gaps",
    "visibility_exceptions",
    "customer_safe",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "corridor_proof_pack_id": { "type": "string", "minLength": 1 },
    "workflow_corridor_spec_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "proof_summary": { "type": "string", "minLength": 10 },
    "claim_mode_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed", "inferred", "hypothesis"],
      "properties": {
        "observed": { "type": "integer", "minimum": 0 },
        "inferred": { "type": "integer", "minimum": 0 },
        "hypothesis": { "type": "integer", "minimum": 0 }
      }
    },
    "claim_register": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "message_id",
          "claim_mode",
          "support_status",
          "proof_refs"
        ],
        "properties": {
          "message_id": { "type": "string", "minLength": 1 },
          "claim_mode": {
            "type": "string",
            "enum": ["observed", "inferred", "hypothesis"]
          },
          "support_status": {
            "type": "string",
            "enum": ["supported", "gap", "bounded"]
          },
          "proof_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "default": []
          },
          "customer_safe": { "type": "boolean", "default": true }
        }
      },
      "minItems": 1
    },
    "proof_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proof_id",
          "label",
          "summary",
          "claim_mode",
          "source_artifact_id",
          "customer_safe"
        ],
        "properties": {
          "proof_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 2 },
          "summary": { "type": "string", "minLength": 8 },
          "claim_mode": {
            "type": "string",
            "enum": ["observed", "inferred", "hypothesis"]
          },
          "source_artifact_id": { "type": "string", "minLength": 1 },
          "customer_safe": { "type": "boolean" }
        }
      },
      "minItems": 1
    },
    "proof_gaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "visibility_exceptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "customer_safe": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
