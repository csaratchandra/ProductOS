{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/runtime_adapter_registry.schema.json",
  "title": "ProductOS Runtime Adapter Registry",
  "description": "Registry of runtime capabilities the host environment currently exposes to ProductOS for live execution behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "runtime_adapter_registry_id",
    "workspace_id",
    "status",
    "default_adapter_id",
    "adapters",
    "evaluated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "runtime_adapter_registry_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "partial",
        "blocked"
      ]
    },
    "default_adapter_id": {
      "type": "string",
      "minLength": 1
    },
    "adapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapter"
      },
      "minItems": 1
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_id",
        "name",
        "capability_type",
        "availability_status",
        "supported_actions",
        "requires_host_support",
        "verification_status",
        "supported_mission_stages",
        "prompt_pattern_capabilities"
      ],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 3
        },
        "capability_type": {
          "type": "string",
          "enum": [
            "worker_session",
            "git_execution",
            "browser_control",
            "filesystem_access",
            "connector_sync",
            "validation_runner",
            "custom"
          ]
        },
        "availability_status": {
          "type": "string",
          "enum": [
            "available",
            "limited",
            "planned",
            "unavailable"
          ]
        },
        "supported_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "requires_host_support": {
          "type": "boolean"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "verified",
            "unverified",
            "planned",
            "failed"
          ]
        },
        "supported_mission_stages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "discover",
              "align",
              "operate",
              "improve"
            ]
          },
          "minItems": 1
        },
        "prompt_pattern_capabilities": {
          "$ref": "#/$defs/capabilityProfile"
        },
        "used_by_default": {
          "type": "boolean",
          "default": false
        },
        "host_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "default": []
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "supportLevel": {
      "type": "string",
      "enum": [
        "native",
        "repo_managed",
        "limited",
        "unsupported"
      ]
    },
    "capabilityProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_routing",
        "task_boundary_visibility",
        "research_freshness",
        "validation_enforcement",
        "delegation_support",
        "approval_gating",
        "memory_steering",
        "artifact_export"
      ],
      "properties": {
        "mission_routing": {
          "$ref": "#/$defs/supportLevel"
        },
        "task_boundary_visibility": {
          "$ref": "#/$defs/supportLevel"
        },
        "research_freshness": {
          "$ref": "#/$defs/supportLevel"
        },
        "validation_enforcement": {
          "$ref": "#/$defs/supportLevel"
        },
        "delegation_support": {
          "$ref": "#/$defs/supportLevel"
        },
        "approval_gating": {
          "$ref": "#/$defs/supportLevel"
        },
        "memory_steering": {
          "$ref": "#/$defs/supportLevel"
        },
        "artifact_export": {
          "$ref": "#/$defs/supportLevel"
        }
      }
    }
  }
}
