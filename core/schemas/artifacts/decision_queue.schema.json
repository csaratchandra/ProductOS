{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/decision_queue.schema.json",
  "title": "ProductOS Decision Queue",
  "description": "Ranked queue of PM decisions that need attention now.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_queue_id",
    "workspace_id",
    "generated_at",
    "decisions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "decision_queue_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionItem"
      }
    }
  },
  "$defs": {
    "decisionOption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "option_id",
        "label"
      ],
      "properties": {
        "option_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 3
        },
        "tradeoffs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "default": []
        },
        "recommended": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "decisionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "title",
        "why_now",
        "options",
        "evidence_strength",
        "recommended_action",
        "status"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 5
        },
        "why_now": {
          "type": "string",
          "minLength": 5
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/decisionOption"
          }
        },
        "evidence_strength": {
          "type": "string",
          "enum": [
            "weak",
            "moderate",
            "strong"
          ]
        },
        "recommended_action": {
          "type": "string",
          "enum": [
            "approve",
            "reject",
            "defer",
            "request_more_evidence"
          ]
        },
        "consequence_of_delay": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "deferred",
            "resolved"
          ]
        }
      }
    }
  }
}
