{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/workspace_adoption_record.schema.json",
  "title": "ProductOS Workspace Adoption Record",
  "description": "Single record showing when a workspace adopted a ProductOS Core version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_id",
    "core_version",
    "adopted_at",
    "approved_by",
    "change_note"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "core_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "adopted_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "change_note": {
      "type": "string",
      "minLength": 5
    }
  }
}
