{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/product_record.schema.json",
  "title": "ProductOS Product Record",
  "description": "Canonical operational tracking record for a product workspace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product_record_id",
    "workspace_id",
    "portfolio_id",
    "mission_ref",
    "product_name",
    "lifecycle_stage",
    "maturity_band",
    "status",
    "owner",
    "review_gate_owner",
    "primary_outcomes",
    "primary_kpis",
    "target_release_or_increment",
    "feature_record_ids",
    "approvals",
    "last_updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "product_record_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "portfolio_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_ref": {
      "type": "string",
      "minLength": 1
    },
    "product_name": {
      "type": "string",
      "minLength": 3
    },
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "discovery",
        "validation",
        "delivery",
        "launch",
        "support",
        "support_learning",
        "improve"
      ]
    },
    "maturity_band": {
      "type": "string",
      "enum": [
        "zero_to_one",
        "one_to_ten",
        "ten_to_hundred",
        "hundred_to_thousand_plus"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "blocked",
        "done",
        "parked"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "review_gate_owner": {
      "type": "string",
      "minLength": 1
    },
    "primary_outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "primary_kpis": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "target_release_or_increment": {
      "type": "string",
      "minLength": 1
    },
    "feature_record_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "dependency_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "risk_summary": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "linked_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "linked_decision_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "approvals": {
      "$ref": "#/$defs/approvals"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "approvals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pm",
        "leadership",
        "customer_commitment",
        "compliance"
      ],
      "properties": {
        "pm": {
          "type": "string",
          "enum": [
            "not_needed",
            "pending",
            "approved"
          ]
        },
        "leadership": {
          "type": "string",
          "enum": [
            "not_needed",
            "pending",
            "approved"
          ]
        },
        "customer_commitment": {
          "type": "string",
          "enum": [
            "not_needed",
            "pending",
            "approved"
          ]
        },
        "compliance": {
          "type": "string",
          "enum": [
            "not_needed",
            "pending",
            "approved"
          ]
        }
      }
    }
  }
}
