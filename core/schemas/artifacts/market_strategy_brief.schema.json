{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/market_strategy_brief.schema.json",
  "title": "ProductOS Market Strategy Brief",
  "description": "Canonical strategy choice for how the product intends to win in a market before concepts, prototypes, and PRDs are committed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "market_strategy_brief_id",
    "workspace_id",
    "title",
    "strategy_question",
    "category_definition",
    "category_maturity",
    "strategic_posture",
    "market_role_goal",
    "target_market_scope",
    "beachhead_segment_refs",
    "priority_persona_refs",
    "competitive_reference_set",
    "offering_definition",
    "offering_type",
    "positioning_statement",
    "value_wedge",
    "right_to_win",
    "proof_requirements",
    "pricing_packaging_hypothesis",
    "gtm_motion",
    "expansion_path",
    "key_risks",
    "evidence_refs",
    "recommendation",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "market_strategy_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "strategy_question": { "type": "string", "minLength": 10 },
    "category_definition": { "type": "string", "minLength": 10 },
    "category_maturity": {
      "type": "string",
      "enum": ["emerging", "growing", "established", "mature"]
    },
    "strategic_posture": {
      "type": "string",
      "enum": ["leader", "challenger", "follower", "niche"]
    },
    "market_role_goal": { "type": "string", "minLength": 10 },
    "target_market_scope": { "type": "string", "minLength": 10 },
    "beachhead_segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "priority_persona_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "buyer_archetype_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "default": []
    },
    "operator_archetype_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "default": []
    },
    "competitive_reference_set": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "minItems": 1
    },
    "offering_definition": { "type": "string", "minLength": 10 },
    "offering_type": {
      "type": "string",
      "enum": [
        "platform",
        "workflow_tool",
        "decision_layer",
        "system_of_record_extension",
        "service_plus_software"
      ]
    },
    "positioning_statement": { "type": "string", "minLength": 10 },
    "value_wedge": { "type": "string", "minLength": 10 },
    "right_to_win": { "type": "string", "minLength": 10 },
    "proof_requirements": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "pricing_packaging_hypothesis": { "type": "string", "minLength": 10 },
    "gtm_motion": { "type": "string", "minLength": 10 },
    "expansion_path": { "type": "string", "minLength": 10 },
    "key_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "rejected_paths": {
      "type": "array",
      "items": { "$ref": "#/$defs/rejectedPath" },
      "default": []
    },
    "linked_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRef" },
      "minItems": 1
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "recommendation": {
      "type": "string",
      "enum": ["commit_posture", "refine_strategy", "gather_more_evidence", "park"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_id", "justification"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["meeting_record", "change_event", "status_mail", "issue_log", "transcript", "decision_log", "research", "other"]
        },
        "source_id": { "type": "string", "minLength": 1 },
        "justification": { "type": "string", "minLength": 5 }
      }
    },
    "rejectedPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_name", "rejection_reason"],
      "properties": {
        "path_name": { "type": "string", "minLength": 3 },
        "rejection_reason": { "type": "string", "minLength": 10 }
      }
    }
  }
}
