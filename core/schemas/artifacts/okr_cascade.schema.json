{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/okr_cascade.schema.json",
  "title": "ProductOS Okr Cascade",
  "description": "OKR cascade mapping company objectives → product key results → feature metrics with measurement methods and targets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "okr_cascade_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "okr_cascade_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}