{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/reliability_state.schema.json",
  "title": "ProductOS Reliability State",
  "description": "Runtime reliability assessment for a workflow or artifact publication decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reliability_state_id",
    "workspace_id",
    "workflow_id",
    "status",
    "confidence_score",
    "publish_blocked",
    "transfer_blocked",
    "reasons",
    "evaluated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "reliability_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "watch",
        "blocked"
      ]
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "publish_blocked": {
      "type": "boolean"
    },
    "transfer_blocked": {
      "type": "boolean"
    },
    "override_required": {
      "type": "boolean",
      "default": false
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
