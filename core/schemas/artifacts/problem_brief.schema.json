{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/problem_brief.schema.json",
  "title": "ProductOS Problem Brief",
  "description": "Decision-ready summary of a validated problem before PRD creation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "problem_brief_id",
    "workspace_id",
    "title",
    "problem_summary",
    "strategic_fit_summary",
    "posture_alignment",
    "why_this_problem_now",
    "why_this_problem_for_this_segment",
    "problem_severity",
    "target_segment_refs",
    "target_persona_refs",
    "linked_entity_refs",
    "evidence_refs",
    "upstream_artifact_ids",
    "canonical_persona_archetype_pack_id",
    "artifact_trace_map_id",
    "ralph_status",
    "prioritization",
    "handoff_readiness_summary",
    "recommended_next_step",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1.0" },
    "problem_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "problem_summary": { "type": "string", "minLength": 10 },
    "strategic_fit_summary": { "type": "string", "minLength": 10 },
    "posture_alignment": {
      "type": "string",
      "enum": ["leader", "challenger", "follower", "niche"]
    },
    "why_this_problem_now": { "type": "string", "minLength": 10 },
    "why_this_problem_for_this_segment": { "type": "string", "minLength": 10 },
    "problem_severity": { "$ref": "#/$defs/problemSeverity" },
    "target_segment_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "target_persona_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "linked_entity_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityRef" },
      "minItems": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRef" },
      "minItems": 1
    },
    "upstream_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "canonical_persona_archetype_pack_id": { "type": "string", "minLength": 1 },
    "artifact_trace_map_id": { "type": "string", "minLength": 1 },
    "ralph_status": {
      "type": "string",
      "enum": ["blocked", "review_needed", "decision_ready"]
    },
    "prioritization": { "$ref": "#/$defs/prioritization" },
    "handoff_readiness_summary": { "type": "string", "minLength": 10 },
    "recommended_next_step": {
      "type": "string",
      "enum": ["research", "prototype", "prd", "park"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "prioritization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "priority_score", "confidence", "agentic_delivery_burden", "priority_rationale", "reviewer_handoff"],
      "properties": {
        "lane": {
          "type": "string",
          "enum": ["must_now", "next", "later", "park"]
        },
        "priority_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "agentic_delivery_burden": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "priority_rationale": { "type": "string", "minLength": 10 },
        "reviewer_handoff": { "type": "string", "minLength": 10 }
      }
    },
    "problemSeverity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["customer_pain", "workflow_frequency", "evidence_strength", "severity_rationale"],
      "properties": {
        "customer_pain": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "workflow_frequency": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "evidence_strength": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "severity_rationale": { "type": "string", "minLength": 10 }
      }
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["segment", "persona", "problem", "outcome", "opportunity", "feature", "metric", "decision"]
        },
        "entity_id": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_id", "justification"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["meeting_record", "change_event", "status_mail", "issue_log", "transcript", "decision_log", "research", "other"]
        },
        "source_id": { "type": "string", "minLength": 1 },
        "justification": { "type": "string", "minLength": 5 }
      }
    }
  }
}
