{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/visual_map_spec.schema.json",
  "title": "ProductOS Visual Map Spec",
  "description": "Typed visual map payload used to render PM maps consistently across slide, memo, dashboard, and workshop forms.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "visual_map_spec_id",
    "workspace_id",
    "map_type",
    "title",
    "decision_use_case",
    "audience",
    "rendering_mode",
    "source_artifact_ids",
    "primary_message",
    "payload",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "visual_map_spec_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "map_type": {
      "type": "string",
      "enum": [
        "roadmap_view",
        "user_journey_map",
        "process_flow",
        "workflow_map",
        "capability_map",
        "product_map",
        "feature_map",
        "mind_map",
        "swot_matrix",
        "impact_effort_matrix"
      ]
    },
    "title": { "type": "string", "minLength": 3 },
    "decision_use_case": { "type": "string", "minLength": 10 },
    "audience": { "type": "string", "minLength": 3 },
    "rendering_mode": {
      "type": "string",
      "enum": ["slide", "memo", "dashboard", "workshop_board"]
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "primary_message": { "type": "string", "minLength": 10 },
    "certainty_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/labeledItem" },
          "default": []
        },
        "lanes": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "default": []
        },
        "stages": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "default": []
        },
        "axes": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "default": []
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/labeledItem" },
          "default": []
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "labeledItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 2 },
        "description": { "type": "string", "minLength": 3 }
      }
    }
  }
}
