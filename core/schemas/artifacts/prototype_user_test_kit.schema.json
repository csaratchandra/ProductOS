{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/prototype_user_test_kit.schema.json",
  "title": "ProductOS Prototype User Test Kit",
  "description": "Complete user testing kit per prototype — task scenarios, moderator guide, observation template, and result capture form.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prototype_user_test_kit_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "prototype_user_test_kit_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}