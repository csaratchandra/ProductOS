{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/cockpit_state.schema.json",
  "title": "ProductOS Cockpit State",
  "description": "PM-facing runtime control-surface state showing current mode, active specialists, queue visibility, and the next controlled step.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cockpit_state_id",
    "workspace_id",
    "mode",
    "status",
    "coordination_status",
    "ralph_stage",
    "mission_control",
    "request_summary",
    "current_focus",
    "recommended_next_step",
    "active_agents",
    "active_queue_refs",
    "queue_recommendations",
    "approval_queue",
    "budget_status",
    "workspace_tree_ref",
    "context_view_refs",
    "recommended_pm_actions",
    "active_orchestration_state_id",
    "active_execution_session_state_ids",
    "active_workflow_state_ids",
    "blocked_route_ids",
    "awaiting_review_route_ids",
    "pending_review_points",
    "blocking_reasons",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "cockpit_state_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "ask",
        "plan",
        "research",
        "prototype",
        "draft",
        "review",
        "status",
        "leadership"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "triaging",
        "routing",
        "active",
        "awaiting_review",
        "blocked",
        "completed"
      ]
    },
    "coordination_status": {
      "type": "string",
      "enum": [
        "healthy",
        "watch",
        "blocked"
      ]
    },
    "ralph_stage": {
      "type": "string",
      "enum": [
        "inspect",
        "implement",
        "refine",
        "validate",
        "fix",
        "revalidate"
      ]
    },
    "mission_control": {
      "$ref": "#/$defs/missionControl"
    },
    "request_summary": {
      "type": "string",
      "minLength": 3
    },
    "current_focus": {
      "type": "string",
      "minLength": 3
    },
    "recommended_next_step": {
      "$ref": "#/$defs/nextStep"
    },
    "active_agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activeAgent"
      },
      "default": []
    },
    "active_queue_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queueRef"
      },
      "default": []
    },
    "queue_recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queueRecommendation"
      },
      "default": []
    },
    "approval_queue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/approvalItem"
      },
      "default": []
    },
    "budget_status": {
      "$ref": "#/$defs/budgetStatus"
    },
    "workspace_tree_ref": {
      "type": "string",
      "minLength": 1
    },
    "context_view_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contextViewRef"
      },
      "default": []
    },
    "recommended_pm_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendationTrace"
      },
      "default": []
    },
    "active_orchestration_state_id": {
      "type": "string",
      "minLength": 1
    },
    "active_execution_session_state_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "active_workflow_state_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "blocked_route_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "awaiting_review_route_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "pending_review_points": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "living_updates_queue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/livingUpdateItem"
      },
      "default": []
    },
    "missing_context_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "default": []
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "missionControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_ref",
        "mission_title",
        "active_stage",
        "current_route_ref",
        "next_route_ref",
        "current_task_name",
        "current_task_summary",
        "current_task_status",
        "reviewer_lane"
      ],
      "properties": {
        "mission_ref": {
          "type": "string",
          "minLength": 1
        },
        "mission_title": {
          "type": "string",
          "minLength": 3
        },
        "active_stage": {
          "type": "string",
          "enum": [
            "discover",
            "align",
            "operate",
            "improve",
            "cross_cutting",
            "none"
          ]
        },
        "current_route_ref": {
          "type": "string",
          "minLength": 1
        },
        "next_route_ref": {
          "type": "string",
          "minLength": 1
        },
        "current_task_name": {
          "type": "string",
          "minLength": 3
        },
        "current_task_summary": {
          "type": "string",
          "minLength": 3
        },
        "current_task_status": {
          "type": "string",
          "minLength": 3
        },
        "reviewer_lane": {
          "type": "string",
          "enum": [
            "ai_reviewer",
            "ai_tester",
            "pm_builder",
            "multi_lane",
            "none"
          ]
        }
      }
    },
    "nextStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_summary",
        "target_type",
        "target_ref",
        "rationale"
      ],
      "properties": {
        "action_summary": {
          "type": "string",
          "minLength": 3
        },
        "target_type": {
          "type": "string",
          "enum": [
            "workflow",
            "agent",
            "queue",
            "pm_review",
            "artifact",
            "none"
          ]
        },
        "target_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "activeAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_name",
        "status",
        "current_task"
      ],
      "properties": {
        "agent_name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "active",
            "awaiting_review",
            "waiting",
            "retrying",
            "paused",
            "blocked",
            "completed"
          ]
        },
        "current_task": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "queueRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_type",
        "artifact_id",
        "summary"
      ],
      "properties": {
        "queue_type": {
          "type": "string",
          "enum": [
            "decision_queue",
            "follow_up_queue",
            "review_queue",
            "custom"
          ]
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "queueRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_type",
        "artifact_id",
        "item_id",
        "recommended_action",
        "urgency",
        "why_now"
      ],
      "properties": {
        "queue_type": {
          "type": "string",
          "enum": [
            "decision_queue",
            "follow_up_queue",
            "review_queue",
            "custom"
          ]
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "recommended_action": {
          "type": "string",
          "enum": [
            "review_now",
            "approve",
            "start",
            "escalate",
            "defer",
            "clear_blocker"
          ]
        },
        "urgency": {
          "type": "string",
          "enum": [
            "routine",
            "time_sensitive",
            "escalated"
          ]
        },
        "why_now": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "approvalItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id",
        "title",
        "owner",
        "status",
        "artifact_refs"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "blocked"]
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "budgetStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "visible_route_count",
        "review_threshold",
        "pause_threshold",
        "pause_reason"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["within_threshold", "watch", "paused"]
        },
        "visible_route_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_threshold": {
          "type": "integer",
          "minimum": 0
        },
        "pause_threshold": {
          "type": "integer",
          "minimum": 0
        },
        "pause_reason": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "contextViewRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_id",
        "label",
        "ref_type",
        "ref_path"
      ],
      "properties": {
        "view_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 2
        },
        "ref_type": {
          "type": "string",
          "enum": ["artifact", "document"]
        },
        "ref_path": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "recommendationTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation_id",
        "summary",
        "source_artifact_refs",
        "observed_vs_inferred",
        "assumption_note"
      ],
      "properties": {
        "recommendation_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 3
        },
        "source_artifact_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "observed_vs_inferred": {
          "type": "string",
          "enum": ["observed", "inferred", "mixed"]
        },
        "assumption_note": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "livingUpdateItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "update_id",
        "regeneration_queue_item_ref",
        "source_change",
        "target_artifact",
        "delta_summary",
        "impact_classification",
        "pm_action"
      ],
      "properties": {
        "update_id": {
          "type": "string",
          "minLength": 1
        },
        "regeneration_queue_item_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_change": {
          "type": "string",
          "minLength": 3
        },
        "target_artifact": {
          "type": "string",
          "minLength": 1
        },
        "delta_summary": {
          "type": "string",
          "minLength": 3
        },
        "impact_classification": {
          "type": "string",
          "enum": ["mechanical", "content_deep", "structural"]
        },
        "pm_action": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "modified"]
        },
        "pm_note": {
          "type": "string",
          "default": ""
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
