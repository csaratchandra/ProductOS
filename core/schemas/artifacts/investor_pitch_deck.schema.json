{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/investor_pitch_deck.schema.json",
  "title": "ProductOS Investor Pitch Deck",
  "description": "12-slide investor pitch deck structure — Problem, Solution, Why Now, Market Size, Product, Traction, Business Model, Competition, Team, Financials, Ask — with per-slide action titles, key messages, supporting data, and source citations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "investor_pitch_deck_id", "workspace_id", "company_name", "slides", "generated_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "investor_pitch_deck_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "company_name": {"type": "string", "minLength": 3},
    "funding_ask": {"type": "string", "minLength": 10},
    "slides": {"type": "array", "items": {"$ref": "#/$defs/slide"}, "minItems": 8, "maxItems": 15},
    "narrative_flow": {"type": "string", "minLength": 30},
    "source_evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "default": []},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "slide": {"type": "object", "additionalProperties": false, "required": ["slide_number", "title", "action_title", "key_message", "supporting_data", "source"], "properties": {"slide_number": {"type": "integer", "minimum": 1}, "title": {"type": "string", "minLength": 3}, "action_title": {"type": "string", "minLength": 10}, "key_message": {"type": "string", "minLength": 20}, "supporting_data": {"type": "array", "items": {"type": "string", "minLength": 5}, "minItems": 1}, "source": {"type": "string", "minLength": 5}}}
  }
}