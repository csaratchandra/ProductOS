{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/social_media_pack.schema.json",
  "title": "ProductOS Social Media Pack",
  "description": "Multi-channel social media content pack — LinkedIn posts, X threads, ProductHunt description, launch week calendar.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "social_media_pack_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "social_media_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}