{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/followup_tracker.schema.json",
  "title": "ProductOS Follow-up Tracker",
  "description": "Tracks open follow-up items from meetings, reviews, and decisions with owners, deadlines, and escalation state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "followup_tracker_id",
    "workspace_id",
    "items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "followup_tracker_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/followupItem"
      }
    },
    "overdue_count": {
      "type": "integer",
      "minimum": 0
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "followupItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "followup_id",
        "description",
        "owner",
        "status",
        "source_type",
        "source_id",
        "due_date"
      ],
      "properties": {
        "followup_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 5
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "in_progress",
            "completed",
            "overdue"
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "meeting",
            "decision",
            "review_gate",
            "stakeholder_request"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "escalated": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
