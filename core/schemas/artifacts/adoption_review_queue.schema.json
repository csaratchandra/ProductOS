{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/adoption_review_queue.schema.json",
  "title": "ProductOS Adoption Review Queue",
  "description": "Review queue created during workspace adoption for low-confidence or blocked inferences.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adoption_review_queue_id",
    "workspace_id",
    "source_workspace_path",
    "generated_artifact_ids",
    "review_items",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "adoption_review_queue_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "source_workspace_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "review_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewItem"
      },
      "minItems": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "reviewItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_item_id",
        "title",
        "uncertainty_type",
        "confidence",
        "status",
        "recommended_reviewer_action"
      ],
      "properties": {
        "review_item_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 5
        },
        "uncertainty_type": {
          "type": "string",
          "enum": [
            "claim_evidence",
            "segment_selection",
            "persona_mapping",
            "commercial_model",
            "security_posture",
            "workflow_scope",
            "artifact_mapping"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "resolved"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "recommended_reviewer_action": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
