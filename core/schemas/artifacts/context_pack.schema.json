{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/context_pack.schema.json",
  "title": "ProductOS Context Pack",
  "description": "Decision-ready context bundle assembled before a bounded ProductOS phase runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context_pack_id",
    "workspace_id",
    "request_summary",
    "decision_to_be_made",
    "status",
    "audience",
    "mission_router",
    "steering_context",
    "quality_contract",
    "evidence_bundle",
    "source_artifact_ids",
    "recommended_next_action",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "context_pack_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "request_summary": { "type": "string", "minLength": 10 },
    "decision_to_be_made": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["ready", "watch", "blocked"]
    },
    "audience": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "mission_router": { "$ref": "#/$defs/missionRouter" },
    "steering_context": { "$ref": "#/$defs/steeringContext" },
    "quality_contract": { "$ref": "#/$defs/qualityContract" },
    "evidence_bundle": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceItem" },
      "minItems": 1
    },
    "contradictions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "default": []
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "recommended_next_action": { "type": "string", "minLength": 10 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "phase": {
      "type": "string",
      "enum": ["discover", "align", "operate", "improve"]
    },
    "reviewerLane": {
      "type": "string",
      "enum": ["ai_reviewer", "ai_tester", "pm_builder"]
    },
    "memoryScope": {
      "type": "string",
      "enum": [
        "decisions",
        "evidence",
        "prior_artifacts",
        "repeated_issues",
        "strategic_memory"
      ]
    },
    "missionRouter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_phase",
        "phase_sequence",
        "primary_reviewer_lane",
        "routing_rationale",
        "stop_conditions"
      ],
      "properties": {
        "entry_phase": { "$ref": "#/$defs/phase" },
        "phase_sequence": {
          "type": "array",
          "items": { "$ref": "#/$defs/phase" },
          "minItems": 1
        },
        "primary_reviewer_lane": { "$ref": "#/$defs/reviewerLane" },
        "routing_rationale": { "type": "string", "minLength": 10 },
        "stop_conditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 8 },
          "minItems": 1
        }
      }
    },
    "steeringContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steering_refs",
        "operating_norms",
        "memory_priority_order",
        "default_artifact_focus"
      ],
      "properties": {
        "steering_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "operating_norms": {
          "type": "array",
          "items": { "type": "string", "minLength": 8 },
          "minItems": 1
        },
        "memory_priority_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/memoryScope" },
          "minItems": 1
        },
        "default_artifact_focus": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        }
      }
    },
    "qualityContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience",
        "decision_needed",
        "evidence",
        "alternatives",
        "recommendation",
        "metrics",
        "risks",
        "owner",
        "next_action"
      ],
      "properties": {
        "audience": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "decision_needed": { "type": "string", "minLength": 10 },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "alternatives": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "recommendation": { "type": "string", "minLength": 10 },
        "metrics": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "owner": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 10 }
      }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "summary",
        "confidence",
        "freshness_status"
      ],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 10 },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshness_status": {
          "type": "string",
          "enum": ["fresh", "usable_with_review", "stale"]
        },
        "claim_mode": {
          "type": "string",
          "enum": ["direct_evidence", "derived_inference", "assumption"]
        }
      }
    }
  }
}
