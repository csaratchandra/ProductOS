{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/meeting_notes.schema.json",
  "title": "ProductOS Meeting Notes",
  "description": "Human-readable meeting notes derived from a transcript.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_notes_id",
    "workspace_id",
    "meeting_record_id",
    "title",
    "summary",
    "key_points",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "meeting_notes_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "meeting_record_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "summary": { "type": "string", "minLength": 10 },
    "key_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 },
      "minItems": 1
    },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
