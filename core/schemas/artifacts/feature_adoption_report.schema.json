{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/feature_adoption_report.schema.json",
  "title": "ProductOS Feature Adoption Report",
  "description": "Feature-level adoption metrics — daily/weekly/monthly active users per feature, adoption rate, stickiness score.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "feature_adoption_report_id",
    "workspace_id",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "feature_adoption_report_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}