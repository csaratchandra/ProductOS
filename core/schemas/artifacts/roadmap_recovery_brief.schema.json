{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/artifacts/roadmap_recovery_brief.schema.json",
  "title": "ProductOS Roadmap Recovery Brief",
  "description": "Now/next/later recovery surface derived from current artifacts such as increment_plan, program_increment_state, decision_queue, open PRD scope, and unresolved evidence gaps.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "roadmap_recovery_brief_id",
    "workspace_id",
    "title",
    "now_items",
    "next_items",
    "later_items",
    "open_decisions",
    "unresolved_evidence_gaps",
    "confidence_assessment",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "roadmap_recovery_brief_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "now_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/roadmapItem" }
    },
    "next_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/roadmapItem" }
    },
    "later_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/roadmapItem" }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_id", "question", "impact", "deadline"],
        "properties": {
          "decision_id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 10 },
          "impact": { "type": "string", "minLength": 10 },
          "deadline": { "type": "string", "minLength": 1 },
          "decision_log_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "unresolved_evidence_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gap_id", "description", "blocking_items"],
        "properties": {
          "gap_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 10 },
          "blocking_items": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "confidence_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_confidence", "biggest_risk", "recommended_focus"],
      "properties": {
        "overall_confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "biggest_risk": { "type": "string", "minLength": 10 },
        "recommended_focus": { "type": "string", "minLength": 10 }
      }
    },
    "source_artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "roadmapItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "title", "summary", "confidence", "artifact_refs"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 3 },
        "summary": { "type": "string", "minLength": 10 },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
