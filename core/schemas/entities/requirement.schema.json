{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/entities/requirement.schema.json",
  "title": "ProductOS Requirement Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "requirement_id",
    "workspace_id",
    "feature_id",
    "statement",
    "requirement_type",
    "priority",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "requirement_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "feature_id": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 10 },
    "requirement_type": {
      "type": "string",
      "enum": ["functional", "non_functional", "policy", "integration", "reporting"]
    },
    "priority": {
      "type": "string",
      "enum": ["must", "should", "could"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "implemented", "deferred"]
    }
  }
}
