{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/entities/decision.schema.json",
  "title": "ProductOS Decision Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "workspace_id",
    "statement",
    "status",
    "rationale",
    "decided_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "decision_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 5 },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "deferred", "rejected", "superseded"]
    },
    "rationale": { "type": "string", "minLength": 5 },
    "decided_at": { "type": "string", "format": "date-time" },
    "linked_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  }
}
