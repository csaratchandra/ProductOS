{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/entities/problem.schema.json",
  "title": "ProductOS Problem Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "problem_id",
    "workspace_id",
    "title",
    "statement",
    "affected_user",
    "severity",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "problem_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "statement": { "type": "string", "minLength": 10 },
    "affected_user": { "type": "string", "minLength": 3 },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "status": {
      "type": "string",
      "enum": ["identified", "validated", "prioritized", "in_progress", "resolved"]
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "linked_segment_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "linked_persona_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  }
}
