{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productos.dev/schemas/entities/prototype.schema.json",
  "title": "ProductOS Prototype Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prototype_id",
    "workspace_id",
    "title",
    "prototype_type",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "prototype_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 3 },
    "prototype_type": {
      "type": "string",
      "enum": ["doc", "wireframe", "mockup", "clickthrough", "service_simulation", "other"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_test", "validated", "invalidated", "inconclusive"]
    },
    "linked_hypothesis_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "linked_problem_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  }
}
